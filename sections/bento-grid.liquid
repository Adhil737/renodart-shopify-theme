{% comment %}
  RenoDart Bento Grid — Phase 3
  ───────────────────────────────
  Mixed-size card grid for category/collage layouts.
  Supports large, tall, wide, and standard card sizes
  with hover zoom, glass labels, and gradient overlays.
{% endcomment %}

{% assign bento_id = 'bento-' | append: section.id %}

<section class="rd-section rd-bento-section" id="{{ bento_id }}">

  {% if section.settings.eyebrow != blank or section.settings.title != blank %}
    <div class="rd-container">
      <div class="rd-section-header rd-section-header--center rd-reveal">
        {% if section.settings.eyebrow != blank %}
          <span class="rd-eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.title != blank %}
          <h2 class="rd-heading-2 rd-section-header__title">{{ section.settings.title }}</h2>
        {% endif %}
      </div>
    </div>
  {% endif %}

  <div class="rd-container">
    <div class="rd-bento-grid rd-stagger">
      {% for block in section.blocks %}
        {% assign img = block.settings.image %}
        {% assign heading = block.settings.heading %}
        {% assign subtitle = block.settings.subtitle %}
        {% assign link = block.settings.link %}
        {% assign card_size = block.settings.card_size | default: 'standard' %}
        {% assign overlay_style = block.settings.overlay_style | default: 'gradient' %}

        <div class="rd-bento-card rd-bento-card--{{ card_size }} rd-reveal" {{ block.shopify_attributes }}
             style="--rd-bento-overlay: {% if overlay_style == 'dark' %}rgba(15,5,32,0.5){% else %}var(--rd-gradient-hero-overlay){% endif %};">
          <a href="{{ link | default: '#' }}" class="rd-bento-card__link" aria-label="{{ heading | escape }}">
            {% if img %}
              <div class="rd-bento-card__image-wrap">
                <img src="{{ img | img_url: 'master' }}"
                     alt="{{ img.alt | default: heading | escape }}"
                     class="rd-bento-card__img"
                     sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                     srcset="{{ img | img_url: '600x' }} 600w,
                             {{ img | img_url: '900x' }} 900w,
                             {{ img | img_url: '1200x' }} 1200w"
                     loading="lazy" />
              </div>
            {% else %}
              <div class="rd-bento-card__image-wrap rd-bento-card__placeholder">
                <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.2">
                  <rect x="10" y="10" width="80" height="80" rx="4"/>
                  <circle cx="35" cy="35" r="8"/>
                  <path d="M10 70l25-20 20 15 15-10 20 25v10H10z"/>
                </svg>
              </div>
            {% endif %}

            <div class="rd-bento-card__overlay"></div>

            <div class="rd-bento-card__content">
              {% if subtitle != blank %}
                <span class="rd-bento-card__subtitle">{{ subtitle }}</span>
              {% endif %}
              {% if heading != blank %}
                <h3 class="rd-bento-card__heading">{{ heading }}</h3>
              {% endif %}
              {% if block.settings.show_arrow %}
                <span class="rd-bento-card__arrow">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              {% endif %}
            </div>
          </a>
        </div>
      {% else %}
        {% comment %}── Onboarding state ──{% endcomment %}
        {% for i in (1..5) %}
          <div class="rd-bento-card rd-bento-card--{% if i == 1 %}large{% elsif i == 2 %}tall{% elsif i == 3 %}wide{% else %}standard{% endif %} rd-reveal">
            <div class="rd-bento-card__image-wrap rd-bento-card__placeholder">
              <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.2">
                <rect x="10" y="10" width="80" height="80" rx="4"/>
                <circle cx="35" cy="35" r="8"/>
                <path d="M10 70l25-20 20 15 15-10 20 25v10H10z"/>
              </svg>
            </div>
            <div class="rd-bento-card__overlay"></div>
            <div class="rd-bento-card__content">
              <h3 class="rd-bento-card__heading">{{ 'homepage.onboarding.no_content' | t }}</h3>
            </div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #{{ bento_id }} .rd-bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 280px;
    gap: var(--rd-grid-gutter);
  }

  #{{ bento_id }} .rd-bento-card--large {
    grid-column: span 2;
    grid-row: span 2;
  }

  #{{ bento_id }} .rd-bento-card--tall {
    grid-column: span 1;
    grid-row: span 2;
  }

  #{{ bento_id }} .rd-bento-card--wide {
    grid-column: span 2;
    grid-row: span 1;
  }

  #{{ bento_id }} .rd-bento-card--standard {
    grid-column: span 1;
    grid-row: span 1;
  }

  @media (max-width: 768px) {
    #{{ bento_id }} .rd-bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 200px;
    }
    #{{ bento_id }} .rd-bento-card--large {
      grid-column: span 2;
      grid-row: span 2;
    }
    #{{ bento_id }} .rd-bento-card--tall,
    #{{ bento_id }} .rd-bento-card--wide,
    #{{ bento_id }} .rd-bento-card--standard {
      grid-column: span 1;
      grid-row: span 1;
    }
  }

  @media (max-width: 480px) {
    #{{ bento_id }} .rd-bento-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }
    #{{ bento_id }} .rd-bento-card--large,
    #{{ bento_id }} .rd-bento-card--tall {
      grid-column: span 1;
      grid-row: span 2;
    }
  }
</style>

{% schema %}
{
  "name": "Bento Grid",
  "class": "bento-grid-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 4,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "row_height",
      "label": "Row height",
      "min": 200,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 280
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Card heading size",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ],
      "default": "md"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "1200 x 800px recommended"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Category Name"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "card_size",
          "label": "Card size",
          "options": [
            { "value": "standard", "label": "Standard (1x1)" },
            { "value": "wide", "label": "Wide (2x1)" },
            { "value": "tall", "label": "Tall (1x2)" },
            { "value": "large", "label": "Large (2x2)" }
          ],
          "default": "standard"
        },
        {
          "type": "select",
          "id": "overlay_style",
          "label": "Overlay style",
          "options": [
            { "value": "gradient", "label": "Gradient" },
            { "value": "dark", "label": "Dark" }
          ],
          "default": "gradient"
        },
        {
          "type": "checkbox",
          "id": "show_arrow",
          "label": "Show arrow icon",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bento Grid",
      "category": "Image",
      "blocks": [
        { "type": "card", "settings": { "card_size": "large" } },
        { "type": "card", "settings": { "card_size": "tall" } },
        { "type": "card", "settings": { "card_size": "standard" } },
        { "type": "card", "settings": { "card_size": "wide" } },
        { "type": "card", "settings": { "card_size": "standard" } }
      ]
    }
  ]
}
{% endschema %}
