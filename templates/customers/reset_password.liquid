<a name="pagecontent" id="pagecontent"></a>

<div class="rd-auth container main content">
  <div class="sixteen columns">
    <div class="rd-auth__header">
      <h1 class="rd-auth__title">{{ 'customer.reset_password.title' | t }}</h1>
      <p class="rd-auth__subtitle"><em>{{ 'customer.reset_password.subtext' | t: email: email }}</em></p>
    </div>

    <div class="rd-auth__card">
      {% form 'reset_customer_password' %}
        {% if form.errors %}
          <div class="rd-auth__errors">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="rd-field">
          <input type="password" value="" name="customer[password]" id="customer_password"
                 class="rd-field__input" placeholder=" " required />
          <label for="customer_password" class="rd-field__label">{{ 'customer.reset_password.password' | t }}</label>
        </div>

        <div class="rd-field">
          <input type="password" value="" name="customer[password_confirmation]" id="customer_password_confirmation"
                 class="rd-field__input" placeholder=" " required />
          <label for="customer_password_confirmation" class="rd-field__label">{{ 'customer.reset_password.password_confirm' | t }}</label>
        </div>

        <div class="rd-auth__actions">
          <input type="submit" class="rd-btn rd-btn--primary rd-btn--lg" value="{{ 'customer.reset_password.submit' | t }}" />
        </div>
      {% endform %}
    </div>
  </div>
</div>
