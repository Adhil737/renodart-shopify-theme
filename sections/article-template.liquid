{% comment %}
  RenoDart Article Post — Phase 6
  ─────────────────────────────────
  TURBO HOOKS PRESERVED:
  · .blog-post-section           → section class
  · .lazyload / data-src / data-srcset → LazySizes
  · .disqus-comment-count / disqus_thread → Disqus integration
  · {% form article %}           → Shopify comment form
  · {% paginate article.comments by 100 %} → Shopify pagination
  · blog-sidebar snippet         → sidebar blocks
  · #comments / #new-comment     → anchor links
  · social-buttons snippet       → share buttons
  New: rd-article layout, cinematic hero banner, sidebar widgets,
  author bio card, comment form with RenoDart styling, related posts.
{% endcomment %}

{% comment %}── Banner hero (article featured image) ──{% endcomment %}
{% if article.image and section.settings.banner_enabled %}
  <section class="rd-page-hero banner center page_banner dark-overlay-{{ section.settings.image_darken }}">
    <img src="{{ article.image | img_url: '100x' }}"
         alt="{{ article.image.alt | default: article.title | escape }}"
         class="rd-page-hero__img lazyload {{ settings.image_loading_style }}"
         data-src="{{ article.image | img_url: '1600x', format: 'pjpg' }}"
         sizes="100vw"
         srcset="{{ article.image | img_url: '480x', format: 'pjpg' }} 480w,
                 {{ article.image | img_url: '768x', format: 'pjpg' }} 768w,
                 {{ article.image | img_url: '1400x', format: 'pjpg' }} 1400w,
                 {{ article.image | img_url: '2048x', format: 'pjpg' }} 2048w"
         width="1600" height="700" loading="eager" fetchpriority="high" />
    <div class="rd-page-hero__overlay" aria-hidden="true"></div>
    <div class="rd-page-hero__content">
      <span class="rd-eyebrow">
        <a href="{{ blog.url }}" style="color:inherit; text-decoration:none;">{{ blog.title }}</a>
      </span>
      <h1 class="rd-page-hero__title">{{ article.title }}</h1>
    </div>
  </section>
{% endif %}

<a name="pagecontent" id="pagecontent"></a>

<div class="rd-article container main content">
  {% paginate article.comments by 100 %}

  {% comment %}── Sidebar detection ──{% endcomment %}
  {% if section.blocks.size > 0 %}{% assign sidebar = true %}{% else %}{% assign sidebar = false %}{% endif %}

  <div class="rd-article__layout {% unless sidebar %}rd-article__layout--no-sidebar{% endunless %}">

    {% comment %}────────────────────────────────────────────
      MAIN ARTICLE COLUMN
    ────────────────────────────────────────────{% endcomment %}
    <main class="rd-article__main" id="main-content" itemprop="mainContentOfPage">

      {% comment %}── Navigation & breadcrumb ──{% endcomment %}
      <div class="rd-article__header">
        <div class="rd-article__header-inner">
          {% comment %}── Breadcrumb ──{% endcomment %}
          {% if section.settings.blog_breadcrumb %}
            <nav class="rd-breadcrumb" aria-label="Breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
              <a href="{{ shop.url }}" class="rd-breadcrumb__link" itemprop="item">
                <span itemprop="name">{{ 'general.breadcrumbs.home' | t }}</span>
              </a>
              <span class="rd-breadcrumb__sep" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </span>
              <a href="{{ blog.url }}" class="rd-breadcrumb__link" itemprop="item">
                <span itemprop="name">{{ blog.title }}</span>
              </a>
              <span class="rd-breadcrumb__sep" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </span>
              <span class="rd-breadcrumb__current">{{ article.title }}</span>
            </nav>
          {% endif %}

          {% comment %}── Prev / next article arrows ──{% endcomment %}
          {% if section.settings.blog_pagination %}
            <div class="rd-article__nav-arrows article-pagination" aria-label="Article navigation">
              {% if blog.next_article %}
                <a href="{{ blog.next_article }}" class="rd-article__nav-arrow">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
                  {{ 'blogs.article.previous_article_html' | t }}
                </a>
              {% endif %}
              {% if blog.previous_article %}
                <a href="{{ blog.previous_article }}" class="rd-article__nav-arrow">
                  {{ 'blogs.article.next_article_html' | t }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>

        {% comment %}── Article title (when no banner) ──{% endcomment %}
        {% unless article.image and section.settings.banner_enabled %}
          {% if section.settings.blog_tags and article.tags.size > 0 %}
            <div class="rd-article__tags">
              {% for tag in article.tags limit: 5 %}
                <a href="{{ shop.url }}/blogs/{{ blog.handle }}/tagged/{{ tag | handleize }}"
                   class="rd-article__tag">{{ tag }}</a>
              {% endfor %}
            </div>
          {% endif %}
          <h1 class="rd-article__title" itemprop="headline">{{ article.title }}</h1>
        {% endunless %}

        {% comment %}── Meta bar ──{% endcomment %}
        <div class="rd-article__meta">
          {% if section.settings.blog_author %}
            <div class="rd-article__meta-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span itemprop="author">{{ article.author }}</span>
            </div>
          {% endif %}
          {% if section.settings.blog_date %}
            <div class="rd-article__meta-item">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
                {{ article.published_at | date: format: "month_day_year" }}
              </time>
            </div>
          {% endif %}
          {% if section.settings.blog_comment_count %}
            {% if settings.disqus_enabled %}
              <div class="rd-article__meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <a href="{{ article.url }}#disqus_thread" data-disqus-identifier="{{ article.id }}"
                   class="disqus-comment-count">{{ 'blogs.counts.comments_with_count' | t: count: 0 }}</a>
              </div>
            {% elsif article.comments_enabled? and article.comments_count > 0 %}
              <div class="rd-article__meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <a href="{{ article.url }}#comments">{{ 'blogs.counts.comments_with_count' | t: count: article.comments_count }}</a>
              </div>
            {% endif %}
          {% endif %}
          {% if section.settings.blog_tags and article.tags.size > 0 %}
            <div class="rd-article__tags" style="margin: 0;">
              {% for tag in article.tags limit: 3 %}
                <a href="{{ shop.url }}/blogs/{{ blog.handle }}/tagged/{{ tag | handleize }}"
                   class="rd-article__tag">{{ tag }}</a>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>

      {% comment %}── Featured image inline (no-banner mode) ──{% endcomment %}
      {% if article.image and section.settings.banner_enabled == false %}
        <div class="rd-article__featured-img-wrap rd-reveal">
          <img src="{{ article.image | img_url: '100x' }}"
               alt="{{ article.image.alt | default: article.title | escape }}"
               class="rd-article__featured-img lazyload {{ settings.image_loading_style }}"
               data-src="{{ article.image | img_url: '1400x', format: 'pjpg' }}"
               data-sizes="auto"
               data-srcset="{{ article.image | img_url: '480x', format: 'pjpg' }} 480w,
                             {{ article.image | img_url: '768x', format: 'pjpg' }} 768w,
                             {{ article.image | img_url: '1400x', format: 'pjpg' }} 1400w"
               width="1400" height="600" loading="lazy" itemprop="image" />
        </div>
      {% endif %}

      {% comment %}── Article body ──{% endcomment %}
      <div class="rd-article__body rd-reveal" itemprop="articleBody">
        {{ article.content }}
      </div>

      {% comment %}── Author bio + social share ──{% endcomment %}
      <div class="rd-article__author-row rd-reveal">
        {% if section.settings.blog_author %}
          <img src="//1.gravatar.com/avatar/{{ article.user.email | md5 }}?s=160&r=G"
               alt="{{ article.author }}"
               class="rd-article__author-avatar"
               width="64" height="64"
               loading="lazy" />
          <div class="rd-article__author-info">
            <p class="rd-article__author-name">{{ article.author }}</p>
            {% if article.user.bio != blank %}
              <p class="rd-article__author-bio">{{ article.user.bio }}</p>
            {% endif %}
          </div>
        {% endif %}
        {% if section.settings.display_social_buttons %}
          <div class="rd-article__share blog_share meta">
            <span class="rd-article__share-label">Share</span>
            {% include 'social-buttons' with 'article' %}
          </div>
        {% endif %}
      </div>

      {% comment %}────────────────────────────────────────────
        COMMENTS
      ────────────────────────────────────────────{% endcomment %}
      <div class="clear" id="comments"></div>

      {% if settings.disqus_enabled %}
        <div id="disqus_thread"></div>
        <script>
          var disqus_config = function () {
            this.page.url = "{{ canonical_url }}";
            this.page.identifier = "{{ article.id }}";
          };
          (function() {
            var d = document, s = d.createElement('script');
            s.src = '//{{ settings.disqus_shortname }}.disqus.com/embed.js';
            s.setAttribute('data-timestamp', +new Date());
            (d.head || d.body).appendChild(s);
          })();
        </script>
        <noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript" rel="nofollow">comments powered by Disqus.</a></noscript>

      {% elsif blog.comments_enabled? %}
        <div class="rd-article__comments-section">

          {% comment %}── Existing comments list ──{% endcomment %}
          {% if article.comments_count > 0 or comment.created_at %}
            <h4 class="rd-article__comments-heading">
              {{ 'blogs.comments.response_count' | t: count: article.comments.size }}
            </h4>

            {% for comment in article.comments %}
              <div id="comment-{{ comment.id }}" class="rd-comment clearfix">
                <img src="//1.gravatar.com/avatar/{{ comment.email | md5 }}?s=96&r=G"
                     alt="{{ comment.author }}"
                     class="rd-comment__avatar"
                     width="48" height="48" loading="lazy" />
                <div class="rd-comment__body">
                  <p class="rd-comment__author">{{ comment.author }}</p>
                  <p class="rd-comment__date">{{ comment.created_at | date: format: "month_day_year" }}</p>
                  <div class="rd-comment__content">{{ comment.content }}</div>
                </div>
              </div>
            {% endfor %}

            {% comment %}── Pending moderated comment ──{% endcomment %}
            {% if comment and comment.created_at %}
              <div id="comment-{{ comment.id }}" class="rd-comment clearfix">
                <img src="//1.gravatar.com/avatar/{{ comment.email | md5 }}?s=96&r=G"
                     alt="{{ comment.author }}"
                     class="rd-comment__avatar"
                     width="48" height="48" loading="lazy" />
                <div class="rd-comment__body">
                  <p class="rd-comment__author">{{ comment.author }}</p>
                  <p class="rd-comment__date">{{ comment.created_at | date: format: "month_day_year" }}</p>
                  <div class="rd-comment__content">{{ comment.content }}</div>
                </div>
              </div>
            {% endif %}

            {% include 'pagination' with sidebar %}
          {% endif %}

          {% comment %}── Comment form ──{% endcomment %}
          <div class="clear" id="new-comment"></div>
          <div class="rd-comment-form rd-reveal">
            <h4 class="rd-comment-form__heading">{{ 'blogs.comments.title' | t }}</h4>

            {% if blog.moderated? %}
              <p class="rd-comment-form__moderation">{{ 'blogs.comments.moderated' | t }}</p>
            {% endif %}

            {% form article %}
              {% if form.posted_successfully? %}
                <div class="rd-article__success-notice">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  {% if blog.moderated? %}
                    {{ 'blogs.comments.success_moderated' | t }}
                  {% else %}
                    {{ 'blogs.comments.success' | t }}
                  {% endif %}
                </div>
              {% endif %}

              {% if form.errors %}
                <div class="rd-article__error-notice">
                  <p>{{ 'general.forms.post_error' | t }}</p>
                </div>
              {% endif %}

              <div class="rd-comment-form__row">
                <div class="rd-comment-form__field">
                  <label for="comment_author" class="rd-comment-form__label">
                    {{ 'blogs.comments.name' | t }} <span class="rd-required">*</span>
                  </label>
                  <input type="text" id="comment_author" name="comment[author]"
                         class="rd-comment-form__input"
                         placeholder="{{ 'blogs.comments.name' | t }}"
                         value="{{ form.author }}" required aria-required="true" />
                </div>
                <div class="rd-comment-form__field">
                  <label for="comment_email" class="rd-comment-form__label">
                    {{ 'blogs.comments.email' | t }} <span class="rd-required">*</span>
                  </label>
                  <input type="email" id="comment_email" name="comment[email]"
                         class="rd-comment-form__input"
                         placeholder="{{ 'blogs.comments.email' | t }}"
                         value="{{ form.email }}" required aria-required="true" />
                </div>
              </div>

              <div class="rd-comment-form__field">
                <label for="comment_body" class="rd-comment-form__label">
                  {{ 'blogs.comments.comment' | t }} <span class="rd-required">*</span>
                </label>
                <textarea id="comment_body" name="comment[body]"
                          class="rd-comment-form__textarea"
                          rows="5"
                          placeholder="{{ 'blogs.comments.comment' | t }}"
                          required aria-required="true">{{ form.body }}</textarea>
              </div>

              <input type="submit" id="comment-submit"
                     class="action_button rd-btn rd-btn--cta"
                     value="{{ 'blogs.comments.post' | t }}" />
            {% endform %}
          </div>
        </div>
      {% endif %}

      {% comment %}── Related posts ──{% endcomment %}
      {% if section.settings.blog_additional_posts and blog.articles_count > 1 %}
        <div class="rd-article__related rd-reveal">
          <div class="rd-section-header rd-section-header--between">
            <div class="rd-section-header__copy">
              <h3 class="rd-heading-3">{{ 'blogs.article.additional_articles' | t: title: blog.title }}</h3>
            </div>
            <a href="{{ blog.url }}" class="rd-btn rd-btn--secondary rd-btn--sm">View all posts</a>
          </div>
          <div class="rd-article__related-grid rd-stagger">
            {% assign article_found = false %}
            {% for a in blog.articles limit: 4 %}
              {% assign skip_article = false %}
              {% if article_found == false and forloop.last %}{% assign skip_article = true %}{% endif %}
              {% if article.id == a.id %}{% assign article_found = true %}{% assign skip_article = true %}{% endif %}
              {% unless skip_article %}
                <article class="rd-blog-card rd-reveal">
                  {% if a.image %}
                    <a href="{{ a.url }}" class="rd-blog-card__img-link">
                      <div class="rd-blog-card__img-wrap">
                        <img src="{{ a.image | img_url: '100x' }}"
                             alt="{{ a.image.alt | default: a.title | escape }}"
                             class="rd-blog-card__img lazyload {{ settings.image_loading_style }}"
                             data-src="{{ a.image | img_url: '600x', format: 'pjpg' }}"
                             data-sizes="auto"
                             data-srcset="{{ a.image | img_url: '400x', format: 'pjpg' }} 400w,
                                          {{ a.image | img_url: '600x', format: 'pjpg' }} 600w"
                             width="600" height="375" loading="lazy" />
                      </div>
                    </a>
                  {% endif %}
                  <div class="rd-blog-card__body">
                    <h5 class="rd-blog-card__title">
                      <a href="{{ a.url }}">{{ a.title }}</a>
                    </h5>
                    <p class="rd-blog-card__meta">
                      {% if section.settings.blog_author %}
                        <span class="rd-blog-card__author">{{ a.author }}</span>
                      {% endif %}
                      {% if section.settings.blog_date %}
                        <time class="rd-blog-card__date" datetime="{{ a.published_at | date: '%Y-%m-%d' }}">
                          {{ a.published_at | date: format: "month_day_year" }}
                        </time>
                      {% endif %}
                    </p>
                    {% if a.excerpt != blank %}
                      <div class="rd-blog-card__excerpt">{{ a.excerpt | strip_html | truncatewords: 20 }}</div>
                    {% endif %}
                    {% if section.settings.read_more_link %}
                      <a href="{{ a.url }}" class="rd-blog-card__link">
                        {{ 'blogs.general.continue_reading_html' | t }}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                      </a>
                    {% endif %}
                  </div>
                </article>
              {% endunless %}
            {% endfor %}
          </div>
        </div>
      {% endif %}

    </main>

    {% comment %}── Sidebar ──{% endcomment %}
    {% if sidebar %}
      {% include 'blog-sidebar', blog_handle: blog.handle %}
    {% endif %}

  </div>
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Blog post",
  "class": "blog-post-section",
  "settings": [
    {
      "type": "header",
      "content": "Banner"
    },
    {
      "type": "checkbox",
      "id": "banner_enabled",
      "label": "Use featured image as hero banner",
      "info": "The blog post's featured image becomes a full-width hero banner",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "image_darken",
      "label": "Darken banner image",
      "default": true
    },
    {
      "type": "header",
      "content": "Post Meta"
    },
    {
      "type": "checkbox",
      "id": "blog_breadcrumb",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "blog_pagination",
      "label": "Show previous / next post arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "blog_tags",
      "label": "Show post tags",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "blog_author",
      "label": "Show author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "blog_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "display_social_buttons",
      "label": "Show social share icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "blog_comment_count",
      "label": "Show comment count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "read_more_link",
      "label": "Show read more link on related posts",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "blog_additional_posts",
      "label": "Show related posts at bottom",
      "default": true
    },
    {
      "type": "header",
      "content": "Sidebar"
    },
    {
      "type": "paragraph",
      "content": "Create a sidebar by adding content blocks."
    },
    {
      "type": "checkbox",
      "id": "toggle",
      "label": "Toggle sidebar content"
    }
  ],
  "blocks": [
    {"type": "search",      "name": "Search form",            "limit": 1},
    {
      "type": "newsletter", "name": "Newsletter sign up form", "limit": 1,
      "settings": [
        {"type": "text",     "id": "newsletter_title", "label": "Heading",    "default": "Subscribe"},
        {"type": "richtext", "id": "newsletter_text",  "label": "Subheading", "default": "<p>Sign up to get the latest on sales, new releases and more \u2026</p>"}
      ]
    },
    {
      "type": "recent_posts", "name": "Recent blog posts", "limit": 1,
      "settings": [
        {
          "type": "select", "id": "blog_post_count", "label": "Display blog posts",
          "options": [{"value": "2","label": "2"},{"value": "5","label": "5"},{"value": "10","label": "10"}],
          "default": "5"
        }
      ]
    },
    {"type": "post_tags", "name": "Blog post tags", "limit": 1},
    {
      "type": "menu", "name": "Menu",
      "settings": [{"type": "link_list", "id": "custom_menu_linklist", "label": "Menu"}]
    },
    {
      "type": "text", "name": "Text",
      "settings": [
        {"type": "text",     "id": "title", "label": "Heading", "default": "Heading"},
        {"type": "richtext", "id": "text",  "label": "Text",    "default": "<p>Text area can be used for details about blog authors or general information.</p>"}
      ]
    },
    {
      "type": "page", "name": "Page",
      "settings": [{"type": "page", "id": "content_page", "label": "Page"}]
    }
  ]
}
{% endschema %}
