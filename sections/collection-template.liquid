{% comment %}
  RenoDart Collection Template — Phase 5
  ────────────────────────────────────────
  Preserved: .product-loop snippet, .js-*, .tag_filter, .sort_by, pagination,
  sidebar include, all Turbo CSS class hooks (.collection-template-section, etc.)
  New: RenoDart hero banner, modern breadcrumb, styled toolbar, rd-product-grid,
  collection description card, empty state, expanded customizer schema.
{% endcomment %}

{% comment %}── Collection hero banner ──{% endcomment %}
{% if section.settings.featured_collection_image %}
  {% assign hero_image = nil %}
  {% if collection.image %}{% assign hero_image = collection.image %}
  {% elsif section.settings.image %}{% assign hero_image = section.settings.image %}
  {% elsif collection.products.first.featured_image %}{% assign hero_image = collection.products.first.featured_image %}
  {% endif %}

  <section class="rd-collection-hero rd-hero rd-hero--{{ section.settings.banner_height }} banner center page_banner dark-overlay-{{ section.settings.image_darken }}"
           style="--rd-hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};">

    <div class="rd-hero__media">
      {% if hero_image %}
        <img src="{{ hero_image | img_url: '100x', format: 'pjpg' }}"
             alt="{{ collection.title | escape }}"
             class="rd-hero__img lazyload {{ settings.image_loading_style }}"
             sizes="100vw"
             data-src="{{ hero_image | img_url: '1600x', format: 'pjpg' }}"
             data-srcset="{{ hero_image | img_url: '480x', format: 'pjpg' }} 480w,
                          {{ hero_image | img_url: '768x', format: 'pjpg' }} 768w,
                          {{ hero_image | img_url: '1100x', format: 'pjpg' }} 1100w,
                          {{ hero_image | img_url: '1600x', format: 'pjpg' }} 1600w,
                          {{ hero_image | img_url: '2000x', format: 'pjpg' }} 2000w"
             width="1600" height="600" loading="eager" />
      {% else %}
        {{ 'collection-1' | placeholder_svg_tag: 'rd-hero__placeholder placeholder-svg placeholder-svg--collection' }}
      {% endif %}
      <div class="rd-hero__overlay rd-hero__overlay--gradient" aria-hidden="true"></div>
    </div>

    {% if section.settings.display_collection_title %}
      <div class="position-center caption js-caption rd-hero__caption">
        <div class="caption-content align-center rd-hero__caption-inner rd-reveal">
          {% if section.settings.collection_eyebrow != blank %}
            <span class="rd-eyebrow">{{ section.settings.collection_eyebrow }}</span>
          {% endif %}
          <h1 class="headline rd-hero__heading rd-display-1">{{ collection.title }}</h1>
          {% if collection.products_count > 0 %}
            <p class="rd-hero__subtitle">
              <span class="rd-collection-count">{{ collection.products_count }}</span>
              {{ 'collections.general.items' | default: 'products' }}
            </p>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </section>
{% endif %}

<a name="pagecontent" id="pagecontent"></a>

<div class="rd-collection container">
  {% paginate collection.products by section.settings.pagination_limit %}

    {% comment %}── Breadcrumb + toolbar ──{% endcomment %}
    <div class="rd-collection__toolbar clearfix breadcrumb-collection">

      {% if section.settings.collection_breadcrumb %}
        <nav class="rd-breadcrumb rd-collection__breadcrumb" aria-label="Breadcrumb"
             itemscope itemtype="http://schema.org/BreadcrumbList">
          <span itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
            <a href="{{ shop.url }}" itemprop="item" class="rd-breadcrumb__link">
              <span itemprop="name">{{ 'general.breadcrumbs.home' | t }}</span>
            </a>
            <meta itemprop="position" content="1" />
          </span>
          <span class="rd-breadcrumb__sep" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </span>
          <span itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
            <a href="/collections/{% if collection.handle != blank %}{{ collection.handle }}{% else %}all{% endif %}"
               itemprop="item" class="rd-breadcrumb__link">
              <span itemprop="name">{{ collection.title }}</span>
            </a>
            <meta itemprop="position" content="2" />
          </span>
          {% if current_tags %}
            {% for tag in current_tags %}
              <span class="rd-breadcrumb__sep" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
              </span>
              <span itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
                <a href="/collections/{% if collection.handle != blank %}{{ collection.handle }}{% else %}all{% endif %}/{{ tag | handleize }}"
                   itemprop="item" class="rd-breadcrumb__link">
                  <span itemprop="name">{{ tag }}</span>
                </a>
              </span>
            {% endfor %}
          {% endif %}
          {% if paginate.pages != 0 %}
            <span class="rd-breadcrumb__sep" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            </span>
            <span class="rd-breadcrumb__current">
              {{ 'general.breadcrumbs.page' | t: current_page: paginate.current_page, pages: paginate.pages }}
            </span>
          {% endif %}
        </nav>
      {% endif %}

      {% comment %}── Collection title (no banner mode) ──{% endcomment %}
      {% if section.settings.display_collection_title and section.settings.featured_collection_image == false %}
        <div class="rd-collection__title-row">
          <h1 class="rd-heading-1 rd-collection__title">{{ collection.title }}</h1>
          {% if collection.products_count > 0 %}
            <span class="rd-badge rd-badge--outline rd-collection__count">{{ collection.products_count }} products</span>
          {% endif %}
        </div>
      {% endif %}

      {% comment %}── Filter + Sort toolbar ──{% endcomment %}
      {% if collection.handle != blank and collection.products_count > 0 %}
        {% if section.settings.collection_tags or section.settings.collection_sort %}
          <div class="rd-collection__filters section_select">

            {% comment %}── Mobile filter toggle ──{% endcomment %}
            <button class="rd-collection__filter-toggle rd-btn rd-btn--sm rd-btn--ghost rd-hide-desktop"
                    id="rd-filter-toggle-{{ section.id }}"
                    aria-expanded="false"
                    aria-controls="rd-filter-drawer-{{ section.id }}">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
              {{ 'collections.general.filter_by' | default: 'Filter' }} &amp; {{ 'collections.sorting.title' | default: 'Sort' }}
            </button>

            {% comment %}── Desktop: chip filter bar ──{% endcomment %}
            {% if section.settings.collection_tags %}
              <div class="rd-collection__chips rd-hide-mobile">
                <a href="{% if collection.handle == "all" %}/collections/all{% else %}{{ collection.url }}{% endif %}"
                   class="rd-chip {% unless current_tags %}rd-chip--active{% endunless %}">
                  {{ 'collections.general.all' | t: title: collection.title | default: 'All' }}
                </a>
                {% for tag in collection.all_tags %}
                  {% unless tag contains 'meta-' %}
                    <a href="/collections/{% if collection.handle != blank %}{{ collection.handle }}{% else %}all{% endif %}/{{ tag | handleize }}"
                       class="rd-chip {% if current_tags contains tag %}rd-chip--active{% endif %}">
                      {{ tag }}
                    </a>
                  {% endunless %}
                {% endfor %}
              </div>
            {% endif %}

            {% if section.settings.collection_sort %}
              <div class="rd-collection__sort-wrap">
                <label for="sort-by" class="rd-sr-only">{{ 'collections.sorting.title' | default: 'Sort by' }}</label>
                <svg class="rd-collection__sort-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5h10M11 9h7M11 13h4M3 17l3 3 3-3M6 20V4"/></svg>
                <select class="sort_by rd-collection__select" id="sort-by"
                        data-default-sort="{{ collection.sort_by | default: collection.default_sort_by }}">
                  <option value="manual">{{ 'collections.sorting.featured' | t }}</option>
                  <option value="best-selling">{{ 'collections.sorting.best_selling' | t }}</option>
                  <option value="title-ascending">{{ 'collections.sorting.az' | t }}</option>
                  <option value="title-descending">{{ 'collections.sorting.za' | t }}</option>
                  <option value="price-ascending">{{ 'collections.sorting.price_ascending' | t }}</option>
                  <option value="price-descending">{{ 'collections.sorting.price_descending' | t }}</option>
                  <option value="created-descending">{{ 'collections.sorting.date_descending' | t }}</option>
                  <option value="created-ascending">{{ 'collections.sorting.date_ascending' | t }}</option>
                </select>
              </div>
            {% endif %}

            {% comment %}── Active filter chips ──{% endcomment %}
            {% if current_tags %}
              <div class="rd-collection__active-chips">
                {% for tag in current_tags %}
                  <a href="/collections/{{ collection.handle }}" class="rd-chip rd-chip--remove">
                    {{ tag }}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
                  </a>
                {% endfor %}
              </div>
            {% endif %}

          </div>

          {% comment %}── Mobile filter drawer ──{% endcomment %}
          <div class="rd-filter-drawer" id="rd-filter-drawer-{{ section.id }}" role="dialog" aria-modal="true" aria-label="{{ 'collections.general.filter_by' | default: 'Filters' }}" hidden>
            <div class="rd-filter-drawer__backdrop" data-filter-close></div>
            <div class="rd-filter-drawer__panel">
              <div class="rd-filter-drawer__header">
                <span class="rd-filter-drawer__title">{{ 'collections.general.filter_by' | default: 'Filters' }}</span>
                <button class="rd-filter-drawer__close" data-filter-close aria-label="Close filters">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </button>
              </div>
              <div class="rd-filter-drawer__body">
                {% if section.settings.collection_tags %}
                  <div class="rd-filter-drawer__group">
                    <span class="rd-filter-drawer__group-title">{{ 'collections.general.filter_by' | default: 'Filter by' }}</span>
                    <div class="rd-filter-drawer__chips">
                      <a href="{% if collection.handle == "all" %}/collections/all{% else %}{{ collection.url }}{% endif %}"
                         class="rd-chip {% unless current_tags %}rd-chip--active{% endunless %}">{{ 'collections.general.all' | t | default: 'All' }}</a>
                      {% for tag in collection.all_tags %}
                        {% unless tag contains 'meta-' %}
                          <a href="/collections/{% if collection.handle != blank %}{{ collection.handle }}{% else %}all{% endif %}/{{ tag | handleize }}"
                             class="rd-chip {% if current_tags contains tag %}rd-chip--active{% endif %}">{{ tag }}</a>
                        {% endunless %}
                      {% endfor %}
                    </div>
                  </div>
                {% endif %}
                {% if section.settings.collection_sort %}
                  <div class="rd-filter-drawer__group">
                    <span class="rd-filter-drawer__group-title">{{ 'collections.sorting.title' | default: 'Sort by' }}</span>
                    <div class="rd-filter-drawer__chips">
                      {% assign sort_options = 'manual,best-selling,title-ascending,title-descending,price-ascending,price-descending,created-descending,created-ascending' | split: ',' %}
                      {% for option in sort_options %}
                        {% assign sort_label = option | replace: 'manual', 'Featured' | replace: 'best-selling', 'Best Selling' | replace: 'title-ascending', 'A-Z' | replace: 'title-descending', 'Z-A' | replace: 'price-ascending', 'Price: Low to High' | replace: 'price-descending', 'Price: High to Low' | replace: 'created-descending', 'Newest' | replace: 'created-ascending', 'Oldest' %}
                        <a href="#" class="rd-chip {% if collection.sort_by == option or collection.sort_by == blank and option == 'manual' %}rd-chip--active{% endif %}" data-sort="{{ option }}">{{ sort_label }}</a>
                      {% endfor %}
                    </div>
                  </div>
                {% endif %}
              </div>
              <div class="rd-filter-drawer__footer">
                <a href="{% if collection.handle == "all" %}/collections/all{% else %}{{ collection.url }}{% endif %}" class="rd-btn rd-btn--sm rd-btn--ghost">{{ 'collections.general.clear_all' | default: 'Clear all' }}</a>
                <button class="rd-btn rd-btn--sm rd-btn--primary" data-filter-close>{{ 'collections.general.apply' | default: 'Apply' }}</button>
              </div>
            </div>
          </div>
        {% endif %}
      {% endif %}

    </div>

    {% comment %}── Divider ──{% endcomment %}
    <div class="sixteen columns">
      <hr class="rd-divider feature_divider" />
    </div>

    {% comment %}── Sidebar detection (preserved) ──{% endcomment %}
    {% if section.blocks.size > 0 %}{% assign sidebar = true %}{% else %}{% assign sidebar = false %}{% endif %}

    {% if sidebar %}
      {% include 'sidebar' %}
      <div class="twelve columns rd-collection__main">
    {% else %}
      <div class="sixteen columns rd-collection__main">
    {% endif %}

      {% comment %}── Collection description ──{% endcomment %}
      {% if collection.description != blank %}
        <div class="rd-collection__description section clearfix collection_description rd-reveal">
          <div class="rd-collection__description-inner">
            {{ collection.description }}
          </div>
        </div>
      {% endif %}

      {% comment %}── Products grid or empty state ──{% endcomment %}
      {% if collection.products.size == 0 %}
        <div class="rd-collection__empty section clearfix collection-matrix rd-reveal">
          <div class="rd-collection__empty-inner">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            <p class="quote rd-collection__empty-text">{{ 'collections.general.no_matches' | t }}</p>
            <a href="/collections/all" class="rd-btn rd-btn--secondary">
              {{ 'collections.general.all_products' | default: 'Browse all products' }}
            </a>
          </div>
        </div>
      {% else %}
        {% assign products_per_row = section.settings.products_per_row %}
        <div class="rd-collection__grid rd-stagger" style="--rd-product-cols-xl: {{ section.settings.products_per_row }};">
          {% include 'product-loop', sidebar: sidebar %}
        </div>
      {% endif %}

      {% if settings.pagination_type == 'basic_pagination' %}
        <div class="rd-collection__pagination">
          {% include 'pagination' with sidebar %}
        </div>
      {% endif %}

    </div>{% comment %}end main columns{% endcomment %}
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Collection",
  "class": "collection-template-section",
  "settings": [
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "select",
      "id": "products_per_row",
      "label": "Products per row",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "pagination_limit",
      "label": "Products per page",
      "options": [
        { "value": "24", "label": "24" },
        { "value": "36", "label": "36" },
        { "value": "48", "label": "48" }
      ],
      "default": "24"
    },
    {
      "type": "header",
      "content": "Collection Info"
    },
    {
      "type": "checkbox",
      "id": "display_collection_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "text",
      "id": "collection_eyebrow",
      "label": "Eyebrow label",
      "info": "Small label above collection title in hero banner (e.g. 'Shop')"
    },
    {
      "type": "checkbox",
      "id": "collection_breadcrumb",
      "label": "Show breadcrumb links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "collection_tags",
      "label": "Enable filtering by product tag"
    },
    {
      "type": "checkbox",
      "id": "collection_sort",
      "label": "Enable collection sorting",
      "default": true
    },
    {
      "type": "header",
      "content": "Banner Image"
    },
    {
      "type": "checkbox",
      "id": "featured_collection_image",
      "label": "Show collection banner image",
      "default": true,
      "info": "Uses the collection's featured image. Upload a fallback image below."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback banner image",
      "info": "1600 x 600px recommended"
    },
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner height",
      "options": [
        { "value": "small",  "label": "Small — 50vh" },
        { "value": "medium", "label": "Medium — 65vh" },
        { "value": "large",  "label": "Large — 80vh" }
      ],
      "default": "small"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 45
    },
    {
      "type": "checkbox",
      "id": "image_darken",
      "label": "Darken banner image",
      "default": true
    },
    {
      "type": "header",
      "content": "Sidebar"
    },
    {
      "type": "paragraph",
      "content": "Create a sidebar by adding content blocks."
    },
    {
      "type": "checkbox",
      "id": "toggle",
      "label": "Toggle sidebar content"
    }
  ],
  "blocks": [
    { "type": "filter_by_tag",        "name": "Tag list",        "limit": 1 },
    { "type": "filter_by_collection", "name": "Collection list", "limit": 1 },
    { "type": "filter_by_type",       "name": "Type list",       "limit": 1 },
    { "type": "filter_by_vendor",     "name": "Vendor list",     "limit": 1 },
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        { "type": "link_list", "id": "custom_menu_linklist", "label": "Menu" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "text",     "id": "title", "label": "Heading", "default": "Heading" },
        { "type": "richtext", "id": "text",  "label": "Text", "default": "<p>Text area can be used for special announcements or general information.</p>" }
      ]
    },
    {
      "type": "page",
      "name": "Page",
      "settings": [
        { "type": "page", "id": "content_page", "label": "Page" }
      ]
    }
  ]
}
{% endschema %}