{% comment %}
  RenoDart Search Results — Phase 6
  ─────────────────────────────────────
  TURBO HOOKS PRESERVED:
  · .search-template-section     → section class
  · .action_button               → submit button
  · settings.search_option       → type filter
  · {% paginate %}               → Shopify pagination
  · product-loop snippet         → product grid for product-only results
  · sidebar blocks               → sidebar snippet
  New: rd-search-results layout, modern search form bar,
  mixed product/article result rows, RenoDart product grid,
  empty state, improved breadcrumb.
{% endcomment %}

{% assign search_pagination = section.settings.pagination_limit %}
{% paginate search.results by search_pagination %}

<a name="pagecontent" id="pagecontent"></a>

<div class="rd-search-results container main content">

  {% comment %}── Sidebar detection ──{% endcomment %}
  {% if section.blocks.size > 0 %}{% assign sidebar = true %}{% else %}{% assign sidebar = false %}{% endif %}

  {% comment %}── Page header ──{% endcomment %}
  <div class="rd-search-results__header rd-reveal">
    {% comment %}── Breadcrumb ──{% endcomment %}
    {% if section.settings.search_breadcrumb %}
      <nav class="rd-breadcrumb" aria-label="Breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
        <a href="{{ shop.url }}" class="rd-breadcrumb__link" itemprop="item">
          <span itemprop="name">{{ 'general.breadcrumbs.home' | t }}</span>
        </a>
        <span class="rd-breadcrumb__sep" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
        <a href="/search" class="rd-breadcrumb__link" itemprop="item">
          <span itemprop="name">{{ 'general.search.title' | t }}</span>
        </a>
        {% if paginate.pages > 1 %}
          <span class="rd-breadcrumb__sep" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </span>
          <span class="rd-breadcrumb__current">{{ 'general.breadcrumbs.page' | t: current_page: paginate.current_page, pages: paginate.pages }}</span>
        {% endif %}
      </nav>
    {% endif %}

    <h1 class="rd-heading-1" style="margin: var(--rd-space-4) 0 var(--rd-space-2);">{{ 'general.search.title' | t }}</h1>
    <hr class="rd-divider" />
  </div>

  <div class="rd-search-results__body {% if sidebar %}rd-search-results__body--sidebar{% endif %}">

    <div class="rd-search-results__main">

      {% comment %}── Search form bar ──{% endcomment %}
      <form class="rd-search-results__form rd-reveal" action="/search" role="search">
        {% if settings.search_option != 'everything' %}
          <input type="hidden" name="type" value="product" />
        {% endif %}
        <svg class="rd-search-results__form-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" name="q" class="rd-search-results__form-input"
               placeholder="{{ 'general.search.placeholder' | t }}"
               value="{{ search.terms | escape }}"
               autocapitalize="off" autocomplete="off" autocorrect="off"
               aria-label="{{ 'general.search.title' | t }}" />
        <button type="submit" class="rd-btn rd-btn--primary rd-btn--sm action_button">
          {{ 'general.search.submit' | t }}
        </button>
      </form>

      {% if search.performed %}

        {% comment %}── Has results ──{% endcomment %}
        {% if search.results.size > 0 %}

          <p class="rd-search-results__count rd-reveal">
            {% assign total = paginate.items %}
            Showing <strong>{{ total }}</strong> result{% if total != 1 %}s{% endif %} for <strong>&ldquo;{{ search.terms | escape }}&rdquo;</strong>
          </p>

          {% comment %}── Product-only results: use product grid ──{% endcomment %}
          {% if settings.search_option != 'everything' or search.results.first.price != blank %}
            {% if search.results.first.price != blank %}
              <div class="rd-search-results__grid rd-stagger">
                {% assign products = search.results %}
                {% assign products_per_row = section.settings.products_per_row %}
                {% include 'product-loop', sidebar: sidebar %}
              </div>
            {% endif %}
          {% endif %}

          {% comment %}── Mixed results (articles + products) ──{% endcomment %}
          {% if settings.search_option == 'everything' and search.results.first.price == blank %}
            <div class="rd-search-results__mixed">
              {% for item in search.results %}
                <div class="rd-search-item rd-reveal">

                  {% comment %}── Item image ──{% endcomment %}
                  <div>
                    {% if item.object_type == 'article' and item.image %}
                      <a href="{{ item.url }}" class="rd-search-item__img-link" aria-label="{{ item.title | escape }}">
                        <img src="{{ item.image | img_url: '240x' }}"
                             alt="{{ item.title | escape }}"
                             class="rd-search-item__img"
                             width="120" height="120" loading="lazy" />
                      </a>
                    {% elsif item.featured_image %}
                      <a href="{{ item.url }}" class="rd-search-item__img-link" aria-label="{{ item.title | escape }}">
                        <img src="{{ item.featured_image | product_img_url: '240x' }}"
                             alt="{{ item.title | escape }}"
                             class="rd-search-item__img"
                             width="120" height="120" loading="lazy" />
                      </a>
                    {% else %}
                      <div class="rd-search-item__img-placeholder">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                      </div>
                    {% endif %}
                  </div>

                  {% comment %}── Item info ──{% endcomment %}
                  <div>
                    <span class="rd-search-item__type">
                      {% if item.object_type == 'article' %}Article{% else %}Product{% endif %}
                    </span>
                    <h3 class="rd-search-item__title">
                      <a href="{{ item.url }}">{{ item.title }}</a>
                    </h3>

                    {% if item.price %}
                      <p class="rd-search-item__price">
                        {% if item.compare_at_price_max > item.price %}
                          <span class="was_price">{{ item.compare_at_price_max | money }}</span>
                        {% endif %}
                        {% if item.available %}
                          {% if item.price_varies %}<small><em>{{ 'products.general.from' | t }}</em></small> {% endif %}
                          {{ item.price_min | money }}
                        {% else %}
                          {{ item.price_min | money }} &ndash; {{ 'products.product.sold_out' | t }}
                        {% endif %}
                      </p>
                    {% endif %}

                    {% if item.object_type == 'article' %}
                      <div class="rd-search-item__meta">
                        {% if section.settings.blog_author and item.author %}
                          <span>{{ 'blogs.article.by_author' | t: author: item.author }}</span>
                        {% endif %}
                        {% if section.settings.blog_date and item.published_at %}
                          <time datetime="{{ item.published_at | date: '%Y-%m-%d' }}">
                            {{ item.published_at | date: format: "month_day_year" }}
                          </time>
                        {% endif %}
                      </div>
                    {% endif %}

                    {% if item.excerpt %}
                      <div class="rd-search-item__excerpt">{{ item.excerpt | strip_html | truncatewords: 30 }}</div>
                      {% if section.settings.read_more_link %}
                        <a href="{{ item.url }}" class="rd-blog-card__link">
                          {{ 'blogs.general.continue_reading_html' | t }}
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        </a>
                      {% endif %}
                    {% else %}
                      <p class="rd-search-item__excerpt">
                        {{ item.content | strip_html | truncatewords: 40 | highlight: search.terms }}
                      </p>
                    {% endif %}
                  </div>

                </div>
              {% endfor %}
            </div>
          {% endif %}

        {% else %}

          {% comment %}── No results state ──{% endcomment %}
          <div class="rd-search-results__empty rd-reveal">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            <h2 class="rd-search-results__empty-title">{{ 'general.search.no_results_html' | t: terms: search.terms | strip_html }}</h2>
            <p class="rd-search-results__empty-text">
              Try checking your spelling or using more general terms.
            </p>
            <a href="/collections/all" class="rd-btn rd-btn--primary rd-btn--lg">Browse all products</a>
          </div>

        {% endif %}

      {% else %}

        {% comment %}── Search not yet performed ──{% endcomment %}
        <div class="rd-search-results__empty rd-reveal">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <h2 class="rd-search-results__empty-title">{{ 'general.search.description' | t }}</h2>
          <p class="rd-search-results__empty-text">Use the search bar above to find products, articles, and pages.</p>
        </div>

      {% endif %}

      {% comment %}── Pagination ──{% endcomment %}
      <div class="rd-blog-listing__pagination">
        {% include 'pagination' with sidebar %}
      </div>

    </div>

    {% comment %}── Sidebar ──{% endcomment %}
    {% if sidebar %}
      {% include 'sidebar' %}
    {% endif %}

  </div>
</div>

{% endpaginate %}

{% schema %}
{
  "name": "Search",
  "class": "search-template-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "search_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "select",
      "id": "products_per_row",
      "label": "Products per row (product results)",
      "options": [
        {"value": "2", "label": "2"},
        {"value": "3", "label": "3"},
        {"value": "4", "label": "4"}
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "pagination_limit",
      "label": "Results per page",
      "options": [
        {"value": "24", "label": "24"},
        {"value": "36", "label": "36"},
        {"value": "48", "label": "48"}
      ],
      "default": "24"
    },
    {
      "type": "header",
      "content": "Article results"
    },
    {
      "type": "checkbox",
      "id": "blog_author",
      "label": "Show author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "read_more_link",
      "label": "Show continue reading link",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "blog_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "header",
      "content": "Sidebar"
    },
    {
      "type": "paragraph",
      "content": "Create a search sidebar by adding content blocks."
    },
    {
      "type": "checkbox",
      "id": "toggle",
      "label": "Toggle sidebar content"
    }
  ],
  "blocks": [
    {"type": "filter_by_collection", "name": "Collection list", "limit": 1},
    {"type": "filter_by_type",       "name": "Type list",       "limit": 1},
    {"type": "filter_by_vendor",     "name": "Vendor list",     "limit": 1},
    {
      "type": "menu", "name": "Menu",
      "settings": [{"type": "link_list", "id": "custom_menu_linklist", "label": "Menu"}]
    },
    {
      "type": "text", "name": "Text",
      "settings": [
        {"type": "text",     "id": "title", "label": "Heading", "default": "Heading"},
        {"type": "richtext", "id": "text",  "label": "Text",    "default": "<p>Text area can be used for special announcements or general information.</p>"}
      ]
    },
    {
      "type": "page", "name": "Page",
      "settings": [{"type": "page", "id": "content_page", "label": "Page"}]
    }
  ]
}
{% endschema %}
