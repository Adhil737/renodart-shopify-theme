{% comment %}
  RenoDart Content Page — Phase 6
  ─────────────────────────────────
  TURBO HOOKS PRESERVED:
  · .page-section                → section class
  · .homepage_content / .featured_content → Turbo JS/CSS hooks
  · page-multi-column snippet    → multi-column page content rendering
  New: rd-content-page wrapper, centered max-width reading layout,
  empty state with onboarding message.
{% endcomment %}

<div class="homepage_content featured_content rd-content-page">
  <div class="rd-container">
    {% if section.settings.content_page != blank %}
      <div class="rd-content-page__inner rd-reveal">
        {% include 'page-multi-column', content: pages[section.settings.content_page].content %}
      </div>
    {% else %}
      <div class="rd-content-page__empty">
        <p class="rd-body">{{ 'homepage.onboarding.no_content' | t }}</p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Page",
  "class": "page-section",
  "settings": [
    {
      "type": "page",
      "id": "content_page",
      "label": "Content page"
    }
  ],
  "presets": [{
    "name": "Page",
    "category": "Text"
  }]
}
{% endschema %}
