{% comment %}
  RenoDart Product Template — Phase 4
  ──────────────────────────────────────
  CRITICAL JS HOOKS PRESERVED (NEVER REMOVE):
  · .js-product_section        → OptionSelectors init
  · .js-product-page-gallery   → Flickity gallery init
  · .js-change-quantity        → +/- quantity buttons
  · data-select-id             → links <select> to OptionSelectors
  · data-enable-state          → URL history on PDP
  · data-product               → JSON for OptionSelectors
  · data-product-id            → product ID reference
  · data-image-id              → variant image switching
  · data-zoom / data-autoplay  → gallery config
  · .action_button.add_to_cart → submit button Turbo hook
  · .current_price / .was_price / .sold_out → selectCallback DOM targets
  · .modal_price               → price container
  · data-remodal-target        → size chart popup
  · .js-load-more              → load-more pagination
{% endcomment %}

<div class="rd-pdp container main content">
  <div class="sixteen columns">

    {% comment %}── Breadcrumb ──{% endcomment %}
    {% if collection.previous_product or collection.next_product or section.settings.product_breadcrumb %}
      <div class="rd-pdp__breadcrumb clearfix breadcrumb-collection">
        {% if section.settings.product_breadcrumb %}
          <nav class="rd-breadcrumb" aria-label="Breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
            <span itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
              <a href="{{ shop.url }}" itemprop="item" class="rd-breadcrumb__link"><span itemprop="name">{{ 'general.breadcrumbs.home' | t }}</span></a>
              <meta itemprop="position" content="1" />
            </span>
            <span class="rd-breadcrumb__sep" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            </span>
            <span itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
              {% if collection %}
                <a href="{{ collection.url }}" itemprop="item" class="rd-breadcrumb__link"><span itemprop="name">{{ collection.title }}</span></a>
              {% else %}
                <a href="/collections/all" class="rd-breadcrumb__link"><span>{{ collections.all.title }}</span></a>
              {% endif %}
              <meta itemprop="position" content="2" />
            </span>
            <span class="rd-breadcrumb__sep" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            </span>
            <span class="rd-breadcrumb__current" aria-current="page">{{ product.title }}</span>
          </nav>
        {% endif %}
        {% if collection.previous_product or collection.next_product %}
          <div class="rd-pdp__nav-arrows nav_arrows breadcrumb_text">
            {% if collection.previous_product %}
              <a href="{{ collection.previous_product }}" class="rd-pdp__nav-arrow breadcrumb_link" title="{{ 'products.general.previous_product_html' | t }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
                <span class="rd-hide-mobile">{{ 'products.general.previous_product_html' | t }}</span>
              </a>
            {% endif %}
            {% if collection.next_product %}
              <a href="{{ collection.next_product }}" class="rd-pdp__nav-arrow breadcrumb_link" title="{{ 'products.general.next_product_html' | t }}">
                <span class="rd-hide-mobile">{{ 'products.general.next_product_html' | t }}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endif %}

  </div>

  {% comment %}── Sidebar detection (preserved) ──{% endcomment %}
  {% if section.blocks.size > 0 %}{% assign sidebar = true %}{% else %}{% assign sidebar = false %}{% endif %}

  <div class="product rd-pdp__layout clearfix">
    {% if sidebar %}{% include 'sidebar' %}<div class="twelve columns">{% else %}<div class="sixteen columns">{% endif %}

    <div class="product-{{ product.id }} rd-pdp__product" data-free-text="{{ settings.free_price_text }}">

      {% comment %}══════════════════════════════════════════════
        MAIN PRODUCT SECTION — Two-column layout
      ══════════════════════════════════════════════{% endcomment %}
      <div class="section product_section js-product_section clearfix rd-pdp__main
                  {% if section.settings.product_images_position == 'right' %}align_right--images rd-pdp__main--img-right{% endif %}"
           itemscope itemtype="http://schema.org/Product">

        {% comment %}── Gallery column ──{% endcomment %}
        <div class="{% if sidebar %}seven{% else %}nine{% endif %} columns {% if section.settings.product_images_position == 'left' %}alpha{% else %}omega{% endif %} rd-pdp__gallery-col">
          {% include 'product-images' %}
        </div>

        {% comment %}── Info column ──{% endcomment %}
        <div class="{% if sidebar %}five{% else %}seven{% endif %} columns {% if section.settings.product_images_position == 'left' %}omega{% else %}alpha{% endif %} rd-pdp__info-col">

          {% assign collection_handles = product.collections | map: 'handle' %}
          {% assign variant = product.selected_or_first_available_variant %}

          {% comment %}── Badges row ──{% endcomment %}
          <div class="rd-pdp__badges">
            {% if settings.sale_banner_enabled and product.compare_at_price_max > product.price %}
              <span class="rd-badge rd-badge--sale sale_banner_product">{{ 'collections.general.sale' | t }}</span>
            {% endif %}
            {% if collection_handles contains 'new' %}
              <span class="rd-badge rd-badge--new new_banner_product">{{ 'collections.general.new' | t }}</span>
            {% endif %}
            {% if collection_handles contains 'pre-order' %}
              <span class="rd-badge rd-badge--outline new_banner_product">{{ 'collections.general.pre_order' | t }}</span>
            {% endif %}
            {% if section.settings.show_trust_badge_top and product.metafields.custom.trust_label != blank %}
              <span class="rd-badge rd-badge--outline rd-pdp__trust-badge-inline">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {{ product.metafields.custom.trust_label }}
              </span>
            {% endif %}
          </div>

          {% comment %}── Vendor ──{% endcomment %}
          {% if section.settings.display_vendor %}
            <p class="vendor rd-pdp__vendor">
              <span itemprop="brand" class="vendor">{{ product.vendor | link_to_vendor }}</span>
            </p>
          {% endif %}

          {% comment %}── SKU ──{% endcomment %}
          {% if variant.sku != blank and section.settings.display_sku %}
            <p class="sku rd-pdp__sku">
              <span class="rd-pdp__sku-label">{{ 'products.product.sku' | default: 'SKU' }}:</span>
              <span itemprop="sku" class="rd-pdp__sku-value">{{ variant.sku }}</span>
            </p>
          {% endif %}

          {% comment %}── Product title ──{% endcomment %}
          <h1 class="product_name rd-pdp__title" itemprop="name">{{ product.title }}</h1>

          {% comment %}── Reviews badge ──{% endcomment %}
          {% if settings.enable_shopify_product_badges and settings.enable_shopify_review_comments %}
            <div class="rd-pdp__reviews-badge">
              <span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span>
            </div>
          {% endif %}

          <div class="feature_divider rd-divider--gradient"></div>

          {% comment %}── Price block ──{% endcomment %}
          {% assign product_tags = product.tags | join: ' ' %}
          {% if collection_handles contains 'coming-soon' %}
            <p class="modal_price rd-pdp__price">{{ 'collections.general.coming_soon' | t }}</p>
          {% else %}
            <div class="rd-pdp__price-block">
              <p class="modal_price rd-pdp__price" itemprop="offers" itemscope itemtype="http://schema.org/Offer">
                <meta itemprop="priceCurrency" content="{{ shop.currency }}" />
                <meta itemprop="seller" content="{{ shop.name | escape }}" />
                <link itemprop="availability" href="http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}">
                <meta itemprop="itemCondition" content="New" />
                <span class="sold_out rd-pdp__sold-out">{% if variant.available == false %}{{ 'products.product.sold_out' | t }}{% endif %}</span>
                <span itemprop="price" content="{{ variant.price | money_without_currency }}" class="rd-pdp__price-current-wrap {% if variant.compare_at_price > variant.price %}sale{% endif %}">
                  <span class="current_price rd-pdp__current-price {% if product.available == false %}hidden{% endif %}">
                    {% if variant.price > 0 %}
                      <span class="money">{{ variant.price | money }}</span>
                    {% else %}
                      {{ settings.free_price_text }}
                    {% endif %}
                  </span>
                </span>
                <span class="was_price rd-pdp__compare-price">
                  {% if variant.price < variant.compare_at_price and variant.available %}
                    <span class="money">{{ variant.compare_at_price | money }}</span>
                  {% endif %}
                </span>
              </p>

              {% comment %}── Discount percentage badge ──{% endcomment %}
              {% if variant.compare_at_price > variant.price and variant.available %}
                {% assign discount_amount = variant.compare_at_price | minus: variant.price %}
                {% assign discount_pct = discount_amount | times: 100 | divided_by: variant.compare_at_price %}
                <span class="rd-pdp__discount-badge rd-badge rd-badge--sale">
                  Save {{ discount_pct }}%
                </span>
              {% endif %}
            </div>

            {% comment %}── Inventory left ──{% endcomment %}
            {% if section.settings.show_inventory_count %}
              {% if variant.inventory_management != blank and variant.inventory_quantity > 0 and variant.inventory_quantity <= section.settings.inventory_threshold %}
                <div class="rd-pdp__stock-warning">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  Only {{ variant.inventory_quantity }} left in stock
                </div>
              {% endif %}
            {% endif %}

            {% include 'product-notify-me' %}
          {% endif %}

          {% comment %}── Size chart ──{% endcomment %}
          {% if product_tags contains 'meta-size-chart-' %}
            {% for tag in product.tags %}
              {% if tag contains 'meta-size-chart-' %}
                <a href="#size-chart{{ product.id }}" class="size_chart rd-pdp__size-chart" data-remodal-target="size-chart{{ product.id }}" data-no-instant>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                  {{ 'products.product.size_chart' | t }}
                </a>
                {% include 'popup-size-chart', product_id: product.id %}
              {% endif %}
            {% endfor %}
          {% elsif settings.size_chart != blank %}
            <a href="#size-chart" class="size_chart rd-pdp__size-chart" data-remodal-target="size-chart" data-no-instant>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              {{ 'products.product.size_chart' | t }}
            </a>
          {% endif %}

          {% comment %}── Description (top position) ──{% endcomment %}
          {% if section.settings.product_description_position == "top" %}
            {% if product.description != blank %}
              <div class="description rd-pdp__description" itemprop="description">
                {{ product.description | split: '<!-- split -->' | first }}
              </div>
            {% endif %}
          {% endif %}

          {% comment %}── Product form (ATC + variants) ──{% endcomment %}
          {% unless collection_handles contains 'coming-soon' %}
            <div class="js-product_section product_section rd-pdp__form-wrap">
              {% include 'product-form' with 'product' %}
            </div>
          {% endunless %}

          {% comment %}── Buy Now button ──{% endcomment %}
          {% if section.settings.show_buy_now and product.available %}
            <div class="rd-pdp__buy-now-wrap">
              <form action="/cart/add" method="post" id="rd-buy-now-form-{{ product.id }}">
                <input type="hidden" name="id" value="{{ variant.id }}" id="rd-buy-now-variant-{{ product.id }}" />
                <input type="hidden" name="return_to" value="/checkout" />
                <button type="submit" class="rd-btn rd-btn--secondary rd-btn--full rd-pdp__buy-now-btn" data-product-id="{{ product.id }}">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                  {{ section.settings.buy_now_text | default: 'Buy Now' }}
                </button>
              </form>
            </div>
          {% endif %}

          {% comment %}── Trust badges row ──{% endcomment %}
          {% if section.settings.show_trust_badges %}
            <div class="rd-pdp__trust-badges">
              {% if section.settings.trust_badge_1 != blank %}
                <div class="rd-pdp__trust-item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  <span>{{ section.settings.trust_badge_1 }}</span>
                </div>
              {% endif %}
              {% if section.settings.trust_badge_2 != blank %}
                <div class="rd-pdp__trust-item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  <span>{{ section.settings.trust_badge_2 }}</span>
                </div>
              {% endif %}
              {% if section.settings.trust_badge_3 != blank %}
                <div class="rd-pdp__trust-item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <span>{{ section.settings.trust_badge_3 }}</span>
                </div>
              {% endif %}
              {% if section.settings.trust_badge_4 != blank %}
                <div class="rd-pdp__trust-item">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                  <span>{{ section.settings.trust_badge_4 }}</span>
                </div>
              {% endif %}
            </div>
          {% endif %}

          {% comment %}── Description (bottom position) ──{% endcomment %}
          {% if section.settings.product_description_position == "bottom" %}
            {% if product.description != blank %}
              <div class="description bottom rd-pdp__description" itemprop="description">
                {{ product.description | split: '<!-- split -->' | first }}
              </div>
            {% endif %}
          {% endif %}

          {% comment %}── Collapsible tabs ──{% endcomment %}
          {% if section.settings.show_tabs %}
            <div class="rd-pdp__tabs" id="rd-pdp-tabs-{{ product.id }}">
              {% if section.settings.tab_1_title != blank %}
                <div class="rd-pdp__tab">
                  <button class="rd-pdp__tab-trigger" aria-expanded="false" aria-controls="rd-tab-1-{{ product.id }}">
                    {{ section.settings.tab_1_title }}
                    <svg class="rd-pdp__tab-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  </button>
                  <div class="rd-pdp__tab-content" id="rd-tab-1-{{ product.id }}" hidden>
                    {{ section.settings.tab_1_content }}
                  </div>
                </div>
              {% endif %}
              {% if section.settings.tab_2_title != blank %}
                <div class="rd-pdp__tab">
                  <button class="rd-pdp__tab-trigger" aria-expanded="false" aria-controls="rd-tab-2-{{ product.id }}">
                    {{ section.settings.tab_2_title }}
                    <svg class="rd-pdp__tab-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  </button>
                  <div class="rd-pdp__tab-content" id="rd-tab-2-{{ product.id }}" hidden>
                    {{ section.settings.tab_2_content }}
                  </div>
                </div>
              {% endif %}
              {% if section.settings.tab_3_title != blank %}
                <div class="rd-pdp__tab">
                  <button class="rd-pdp__tab-trigger" aria-expanded="false" aria-controls="rd-tab-3-{{ product.id }}">
                    {{ section.settings.tab_3_title }}
                    <svg class="rd-pdp__tab-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  </button>
                  <div class="rd-pdp__tab-content" id="rd-tab-3-{{ product.id }}" hidden>
                    {{ section.settings.tab_3_content }}
                  </div>
                </div>
              {% endif %}
            </div>
          {% endif %}

          {% comment %}── Product meta links ──{% endcomment %}
          {% if section.settings.display_collections or section.settings.display_tags or section.settings.display_type %}
            <div class="product_links rd-pdp__meta-links">
              {% if section.settings.display_collections %}
                <p class="rd-pdp__meta-row">
                  <span class="label rd-pdp__meta-label">{{ 'products.product.collections' | t }}:</span>
                  {% for col in product.collections %}<a href="{{ col.url }}" class="rd-pdp__meta-link">{{ col.title }}</a>{% unless forloop.last %}, {% endunless %}{% endfor %}
                </p>
              {% endif %}
              {% if section.settings.display_type %}
                <p class="rd-pdp__meta-row">
                  <span class="label rd-pdp__meta-label">{{ 'products.product.product_types' | t }}:</span>
                  <span>{{ product.type | link_to_type }}</span>
                </p>
              {% endif %}
              {% if section.settings.display_tags %}
                <p class="rd-pdp__meta-row">
                  <span class="label rd-pdp__meta-label">{{ 'products.product.tags' | t }}:</span>
                  {% for tag in product.tags %}
                    {% unless tag contains 'meta-' %}
                      <a href="/collections/{% if collection %}{{ collection.handle }}{% else %}all{% endif %}/{{ tag | handle }}" class="rd-pdp__tag">{{ tag }}</a>{% unless forloop.last %}, {% endunless %}
                    {% endunless %}
                  {% endfor %}
                </p>
              {% endif %}
            </div>
          {% endif %}

          {% comment %}── Social share ──{% endcomment %}
          {% if section.settings.display_social_buttons %}
            <div class="meta rd-pdp__social">{% include 'social-buttons' with 'product' %}</div>
          {% endif %}

          {% comment %}── Reviews (next to gallery position) ──{% endcomment %}
          {% if settings.enable_shopify_review_comments and settings.review_position == "next_to_gallery" %}
            <div id="shopify-product-reviews" data-id="{{ product.id }}" class="rd-pdp__reviews">{{ product.metafields.spr.reviews }}</div>
          {% endif %}

        </div>{% comment %}end info col{% endcomment %}
      </div>{% comment %}end product_section{% endcomment %}

      {% comment %}── Full description after split ──{% endcomment %}
      {% if product.description contains '<!-- split -->' %}
        <div class="section rd-pdp__full-description clearfix">
          <div class="description rd-pdp__description-full">{{ product.description | split: '<!-- split -->' | last }}</div>
        </div>
      {% endif %}

      {% comment %}── Reviews (below gallery position) ──{% endcomment %}
      {% if settings.enable_shopify_review_comments and settings.review_position == "below_gallery" %}
        <div class="shopify-reviews rd-pdp__reviews-below">
          <div id="shopify-product-reviews" data-id="{{ product.id }}">{{ product.metafields.spr.reviews }}</div>
        </div>
      {% endif %}

    </div>{% comment %}end product-ID wrapper{% endcomment %}

  {% comment %}── Related products ──{% endcomment %}
  {% if section.settings.display_related_products and sidebar == false %}
    </div></div>
    {% if section.settings.related_products_heading != blank %}
      <div class="rd-container rd-pdp__related-heading">
        <div class="rd-section-header rd-section-header--center">
          <span class="rd-eyebrow">{{ section.settings.related_products_eyebrow | default: 'You may also like' }}</span>
          <h2 class="rd-heading-1 rd-section-header__title">{{ section.settings.related_products_heading }}</h2>
        </div>
      </div>
    {% endif %}
    {% include 'related-products' %}
  {% elsif section.settings.display_related_products and sidebar == true %}
    {% include 'related-products' %}
    </div></div>
  {% else %}
    </div></div>
  {% endif %}

</div>

{% comment %}── Sticky mobile ATC ──{% endcomment %}
{% if section.settings.show_sticky_atc %}
  <div class="rd-sticky-atc" id="rd-sticky-atc-{{ product.id }}" aria-hidden="true" aria-label="Quick add to cart">
    <div class="rd-sticky-atc__inner rd-container">
      <div class="rd-sticky-atc__product">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | product_img_url: '80x' }}" alt="{{ product.title | escape }}" class="rd-sticky-atc__img" width="48" height="48" loading="lazy" />
        {% endif %}
        <div class="rd-sticky-atc__info">
          <span class="rd-sticky-atc__title">{{ product.title }}</span>
          <span class="rd-sticky-atc__price">
            <span class="money rd-sticky-atc__price-val">{{ variant.price | money }}</span>
            {% if variant.compare_at_price > variant.price %}<span class="money rd-sticky-atc__price-compare">{{ variant.compare_at_price | money }}</span>{% endif %}
          </span>
        </div>
      </div>
      <button type="button" class="rd-btn rd-btn--cta rd-sticky-atc__btn js-rd-sticky-atc-btn" data-product-id="{{ product.id }}" data-variant-id="{{ variant.id }}" {% unless product.available %}disabled{% endunless %}>
        {% if product.available %}{{ 'products.product.add_to_cart' | t }}{% else %}{{ 'products.product.sold_out' | t }}{% endif %}
      </button>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Product",
  "class": "product-template",
  "settings": [
    {
      "type": "header",
      "content": "Product Gallery"
    },
    {
      "type": "checkbox",
      "id": "gallery_arrows",
      "label": "Show gallery arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "activate_zoom",
      "label": "Magnify images on hover"
    },
    {
      "type": "checkbox",
      "id": "enable_product_lightbox",
      "label": "Enable image popup (lightbox)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "activate_autoplay",
