{% comment %}
  RenoDart Logo Bar — Phase 5
  ────────────────────────────
  Preserved: .logo-list-section, block settings (image + link)
  New: rd-section wrapper, marquee animation option, glassmorphism card,
  title with eyebrow, hover opacity effect, expanded schema.
{% endcomment %}

<section class="rd-logo-bar rd-section rd-section--sm logo-list-section
                {% if section.settings.dark_mode %}rd-section--dark{% endif %}">

  <div class="rd-container container">
    <div class="sixteen columns logo-bar-section">

      {% comment %}── Optional heading ──{% endcomment %}
      {% if section.settings.title != blank or section.settings.eyebrow != blank %}
        <div class="rd-logo-bar__header rd-section-header rd-section-header--center rd-reveal">
          {% if section.settings.eyebrow != blank %}
            <span class="rd-eyebrow">{{ section.settings.eyebrow }}</span>
          {% endif %}
          {% if section.settings.title != blank %}
            <h2 class="rd-heading-4 rd-logo-bar__title title center">{{ section.settings.title | escape }}</h2>
          {% endif %}
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="logo-bar rd-logo-bar__track rd-stagger {% if section.settings.marquee_mode %}rd-logo-bar__track--marquee{% endif %}">
          {% for block in section.blocks %}
            <div class="logo-bar__item rd-logo-bar__item" {{ block.shopify_attributes }}>
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="logo-bar__link rd-logo-bar__link" target="_blank" rel="noopener" aria-label="{{ block.settings.image.alt | default: 'Brand logo' | escape }}">
              {% endif %}
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | img_url: '100x' }}"
                     alt="{{ block.settings.image.alt | default: '' | escape }}"
                     class="rd-logo-bar__img lazyload {{ settings.image_loading_style }}"
                     data-sizes="auto"
                     data-src="{{ block.settings.image | img_url: '300x' }}"
                     data-srcset="{{ block.settings.image | img_url: '150x' }} 150w,
                                   {{ block.settings.image | img_url: '300x' }} 300w"
                     width="150" height="60"
                     loading="lazy" />
              {% else %}
                {{ 'logo' | placeholder_svg_tag: 'placeholder-svg rd-logo-bar__placeholder' }}
              {% endif %}
              {% if block.settings.link != blank %}
                </a>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Logo list",
  "class": "logo-list-section",
  "max_blocks": 20,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "info": "Small label above heading (e.g. 'As seen in')"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "As Seen In"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "dark_mode",
      "label": "Dark background",
      "default": false,
      "info": "Uses the brand dark color as section background"
    },
    {
      "type": "checkbox",
      "id": "marquee_mode",
      "label": "Enable scrolling marquee",
      "default": false,
      "info": "Logos scroll horizontally on a continuous loop"
    }
  ],
  "blocks": [
    {
      "type": "logo_image",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image",
          "info": "300 x 100px recommended. Use PNG with transparent background."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Optional — link logo to brand website"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo list",
      "category": "Image",
      "settings": {
        "title": "As Seen In"
      },
      "blocks": [
        { "type": "logo_image" },
        { "type": "logo_image" },
        { "type": "logo_image" },
        { "type": "logo_image" },
        { "type": "logo_image" }
      ]
    }
  ]
}
{% endschema %}
