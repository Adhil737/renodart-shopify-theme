{% comment %}
  RenoDart Footer — Phase 2 Modernization
  ─────────────────────────────────────────
  Architecture:
  • Cinematic deep purple gradient background
  • Preserved all block types: logo, link_list, text, page, empty
  • Preserved toggle_content accordion JS hooks
  • Added: newsletter block, contact info block, social icons row
  • Mobile: accordion collapse behavior preserved
  • New customizer settings for spacing, colors, layout
{% endcomment %}

<footer class="rd-footer footer" role="contentinfo">

  {% comment %}── Decorative top border gradient ──{% endcomment %}
  <div class="rd-footer__border" aria-hidden="true"></div>

  {% comment %}── Newsletter band (optional, above main footer) ──{% endcomment %}
  {% if section.settings.show_newsletter_band and section.settings.newsletter_band_text != blank %}
    <div class="rd-footer__newsletter-band">
      <div class="rd-container">
        <div class="rd-footer__newsletter-inner">
          <div class="rd-footer__newsletter-copy">
            {% if section.settings.newsletter_band_heading != blank %}
              <h3 class="rd-footer__newsletter-heading">{{ section.settings.newsletter_band_heading }}</h3>
            {% endif %}
            <p class="rd-footer__newsletter-text">{{ section.settings.newsletter_band_text }}</p>
          </div>
          <form action="/contact#contact_form" method="post" accept-charset="UTF-8" class="rd-footer__newsletter-form" id="footer-newsletter-form">
            <input type="hidden" name="form_type" value="customer" />
            <input type="hidden" name="utf8" value="✓" />
            <input type="hidden" name="contact[tags]" value="newsletter" />
            <div class="rd-footer__newsletter-field">
              <label for="footer-email" class="rd-sr-only">{{ 'general.newsletter_form.email_placeholder' | t }}</label>
              <input type="email" name="contact[email]" id="footer-email" class="rd-footer__newsletter-input" placeholder="{{ 'general.newsletter_form.email_placeholder' | t }}" autocomplete="email" required aria-required="true" />
              <button type="submit" class="rd-btn rd-btn--cta rd-footer__newsletter-btn">
                {{ section.settings.newsletter_btn_text | default: 'Subscribe' }}
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  {% endif %}

  {% comment %}── Main footer body ──{% endcomment %}
  <div class="rd-footer__body">
    <div class="rd-container">
      <div class="rd-footer__grid container footer-menu-wrap">

        {% for block in section.blocks %}
          <div class="rd-footer__col {% if forloop.length >= 5 %}three columns{% elsif forloop.length == 4 %}four columns{% elsif forloop.length == 3 %}one-third column{% elsif forloop.length == 2 %}eight columns{% endif %}" {{ block.shopify_attributes }}>

            {% if block.type == 'logo' %}
              {% comment %}── Logo block ──{% endcomment %}
              <div class="rd-footer__logo-block text-align--{{ block.settings.text_align }}">
                {% if block.settings.image %}
                  <a href="{{ shop.url }}" class="rd-footer__logo-link" title="{{ shop.name | escape }}">
                    <img src="{{ block.settings.image | img_url: '100x' }}"
                         alt="{{ block.settings.image.alt | default: shop.name | escape }}"
                         class="footer-logo rd-footer__logo lazyload {{ settings.image_loading_style }}"
                         data-sizes="auto"
                         data-src="{{ block.settings.image | img_url: '400x' }}"
                         data-srcset="{{ block.settings.image | img_url: '200x' }} 200w,
                                      {{ block.settings.image | img_url: '300x' }} 300w,
                                      {{ block.settings.image | img_url: '400x' }} 400w"
                         width="200" height="60" loading="lazy" />
                  </a>
                {% else %}
                  <a href="{{ shop.url }}" class="rd-footer__logo-text logo">{{ shop.name }}</a>
                {% endif %}
                {% if block.settings.tagline != blank %}
                  <p class="rd-footer__tagline">{{ block.settings.tagline }}</p>
                {% endif %}
                {% if block.settings.social_icons_footer %}
                  <div class="footer-social-icons rd-footer__social">{% include 'social-icons' %}</div>
                {% endif %}
              </div>

            {% elsif block.type == 'link_list' %}
              {% comment %}── Menu block ──{% endcomment %}
              <div class="footer_menu rd-footer__menu-block">
                {% if block.settings.menu != blank %}
                  <h6 class="rd-footer__col-heading">
                    {{ linklists[block.settings.menu].title }}
                    <span class="right icon-down-arrow rd-footer__accordion-icon" aria-hidden="true"></span>
                  </h6>
                  <div class="toggle_content rd-footer__col-content">
                    <ul class="rd-footer__links">
                      {% for link in linklists[block.settings.menu].links %}
                        <li><a href="{{ link.url }}" class="rd-footer__link">{{ link.title }}</a></li>
                      {% endfor %}
                    </ul>
                  </div>
                {% else %}
                  <h6 class="rd-footer__col-heading">Menu title <span class="right icon-down-arrow rd-footer__accordion-icon" aria-hidden="true"></span></h6>
                  <div class="toggle_content rd-footer__col-content">
                    <ul class="rd-footer__links"><li><p>{{ 'homepage.onboarding.no_content' | t }}</p></li></ul>
                  </div>
                {% endif %}
                {% if block.settings.social_icons_footer %}
                  <div class="footer-social-icons rd-footer__social">{% include 'social-icons' %}</div>
                {% endif %}
              </div>

            {% elsif block.type == 'text' %}
              {% comment %}── Text block ──{% endcomment %}
              <div class="footer_content rd-footer__text-block">
                {% if block.settings.title != blank %}
                  <h6 class="rd-footer__col-heading">
                    {{ block.settings.title }}
                    <span class="right icon-down-arrow rd-footer__accordion-icon" aria-hidden="true"></span>
                  </h6>
                  <div class="toggle_content rd-footer__col-content rd-footer__richtext">
                    {{ block.settings.content }}
                  </div>
                {% endif %}
                {% if block.settings.social_icons_footer %}
                  <div class="footer-social-icons rd-footer__social">{% include 'social-icons' %}</div>
                {% endif %}
              </div>

            {% elsif block.type == 'page' %}
              {% comment %}── Page block ──{% endcomment %}
              <div class="footer_content rd-footer__page-block">
                {% if block.settings.page != blank %}
                  <h6 class="rd-footer__col-heading">
                    {{ pages[block.settings.page].title }}
                    <span class="right icon-down-arrow rd-footer__accordion-icon" aria-hidden="true"></span>
                  </h6>
                  <div class="toggle_content rd-footer__col-content rd-footer__richtext">
                    {{ pages[block.settings.page].content }}
                  </div>
                {% else %}
                  <h6 class="rd-footer__col-heading">Page title <span class="right icon-down-arrow rd-footer__accordion-icon" aria-hidden="true"></span></h6>
                  <div class="toggle_content rd-footer__col-content"><p>{{ 'homepage.onboarding.no_content' | t }}</p></div>
                {% endif %}
                {% if block.settings.social_icons_footer %}
                  <div class="footer-social-icons rd-footer__social">{% include 'social-icons' %}</div>
                {% endif %}
              </div>

            {% elsif block.type == 'contact' %}
              {% comment %}── Contact info block (new) ──{% endcomment %}
              <div class="rd-footer__contact-block">
                {% if block.settings.title != blank %}
                  <h6 class="rd-footer__col-heading">
                    {{ block.settings.title }}
                    <span class="right icon-down-arrow rd-footer__accordion-icon" aria-hidden="true"></span>
                  </h6>
                {% endif %}
                <div class="toggle_content rd-footer__col-content">
                  <ul class="rd-footer__contact-list">
                    {% if block.settings.address != blank %}
                      <li class="rd-footer__contact-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        <span>{{ block.settings.address }}</span>
                      </li>
                    {% endif %}
                    {% if block.settings.phone != blank %}
                      <li class="rd-footer__contact-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        <a href="tel:{{ block.settings.phone | replace: ' ', '' }}">{{ block.settings.phone }}</a>
                      </li>
                    {% endif %}
                    {% if block.settings.email != blank %}
                      <li class="rd-footer__contact-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
                      </li>
                    {% endif %}
                    {% if block.settings.hours != blank %}
                      <li class="rd-footer__contact-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <span>{{ block.settings.hours }}</span>
                      </li>
                    {% endif %}
                  </ul>
                </div>
                {% if block.settings.social_icons_footer %}
                  <div class="footer-social-icons rd-footer__social">{% include 'social-icons' %}</div>
                {% endif %}
              </div>

            {% elsif block.type == 'empty' %}
              <div class="empty-column rd-footer__empty-col"></div>

            {% endif %}

          </div>
        {% endfor %}

        {% comment %}── Mobile social icons row (preserved) ──{% endcomment %}
        {% assign social_icons = false %}
        {% for block in section.blocks %}
          {% if block.settings.social_icons_footer %}{% assign social_icons = true %}{% endif %}
        {% endfor %}
        {% if social_icons %}
          <div class="footer-social-icons--mobile sixteen columns rd-footer__social-mobile">
            {% include 'social-icons' %}
          </div>
        {% endif %}

      </div>
    </div>
  </div>

  {% comment %}── Footer bottom bar ──{% endcomment %}
  <div class="rd-footer__bottom">
    <div class="rd-container">
      <div class="sixteen columns row footer_credits rd-footer__credits">
        <p class="credits rd-footer__copyright">
          &copy; {{ "now" | date: "%Y" }} {{ shop.name | link_to: '/' }}.
          {% if section.settings.copyright_text != blank %}{{ section.settings.copyright_text }}{% endif %}
          {% if section.settings.display_designed_by %}{{ 'layout.general.designer_credits_html' | t }}{% endif %}
        </p>
        {% if section.settings.display_payment_methods %}
          <div class="payment_methods rd-footer__payments">
            {% for type in shop.enabled_payment_types %}
              <img src="{{ type | payment_type_img_url }}" alt="{{ type | replace: '_', ' ' | capitalize }}" loading="lazy" />
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "class": "footer-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Newsletter Band"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter_band",
      "label": "Show newsletter signup band",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_band_heading",
      "label": "Newsletter heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "newsletter_band_text",
      "label": "Newsletter subtext",
      "default": "New arrivals, exclusive drops, and members-only offers."
    },
    {
      "type": "text",
      "id": "newsletter_btn_text",
      "label": "Subscribe button text",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Footer Bottom"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text"
    },
    {
      "type": "checkbox",
      "id": "display_designed_by",
      "label": "Show theme designer credits",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "display_payment_methods",
      "label": "Show payment method icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Alignment",
          "options": [
            { "value": "left",   "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "info": "Short brand description below the logo"
        },
        {
          "type": "checkbox",
          "id": "social_icons_footer",
          "label": "Show social icons",
          "default": true
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "checkbox",
          "id": "social_icons_footer",
          "label": "Show social icons",
          "default": false
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "About Us"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Use this text to share information about your brand with your customers.</p>"
        },
        {
          "type": "checkbox",
          "id": "social_icons_footer",
          "label": "Show social icons",
          "default": false
        }
      ]
    },
    {
      "type": "page",
      "name": "Page",
      "limit": 1,
      "settings": [
        {
          "type": "page",
          "id": "page",
          "label": "Content page"
        },
        {
          "type": "checkbox",
          "id": "social_icons_footer",
          "label": "Show social icons",
          "default": false
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact Info",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Contact Us"
        },
        {
          "type": "text",
          "id": "address",
          "label": "Address"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone number"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email address"
        },
        {
          "type": "text",
          "id": "hours",
          "label": "Business hours",
          "default": "Mon–Fri: 9am – 6pm"
        },
        {
          "type": "checkbox",
          "id": "social_icons_footer",
          "label": "Show social icons",
          "default": false
        }
      ]
    },
    {
      "type": "empty",
      "name": "Empty column",
      "settings": [
        {
          "type": "checkbox",
          "id": "social_icons_footer",
          "label": "Show social icons",
          "default": false
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "logo" },
      { "type": "link_list" },
      { "type": "link_list" },
      { "type": "contact" }
    ]
  }
}
{% endschema %}
