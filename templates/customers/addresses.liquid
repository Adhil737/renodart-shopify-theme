<a name="pagecontent" id="pagecontent"></a>

<div class="rd-addresses container main content">
  <div class="sixteen columns">
    <div class="rd-addresses__header">
      <h1 class="rd-account__title">{{ 'customer.addresses.title' | t }}</h1>
      <div class="rd-account__logout">
        <a href="/account">{{ 'customer.account.return' | t }}</a>
        <span style="margin-left: var(--rd-space-2);">{{ 'layout.customer.log_out' | t | customer_logout_link }}</span>
      </div>
    </div>

    <hr class="rd-divider" />

    <div style="margin-bottom: var(--rd-space-6);">
      <button class="rd-btn rd-btn--secondary" onclick="Shopify.CustomerAddress.toggleNewForm(); return false;">
        {{ 'customer.addresses.add_new' | t }}
      </button>
    </div>

    {% comment %}── New address form ──{% endcomment %}
    <div id="add_address" class="rd-auth__card rd-auth__card--wide" style="display:none; margin-bottom: var(--rd-space-8);">
      {% form 'customer_address', customer.new_address %}
        <h2 class="rd-account__main-heading">{{ 'customer.addresses.add_new' | t }}</h2>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0 var(--rd-space-4);">
          <div class="rd-field">
            <input type="text" id="address_first_name_new" class="rd-field__input" placeholder=" " name="address[first_name]" value="{{form.first_name}}" autocapitalize="words" />
            <label for="address_first_name_new" class="rd-field__label">{{ 'customer.addresses.first_name' | t }}</label>
          </div>
          <div class="rd-field">
            <input type="text" id="address_last_name_new" class="rd-field__input" placeholder=" " name="address[last_name]" value="{{form.last_name}}" autocapitalize="words" />
            <label for="address_last_name_new" class="rd-field__label">{{ 'customer.addresses.last_name' | t }}</label>
          </div>
        </div>

        <div class="rd-field">
          <input type="text" id="address_company_new" class="rd-field__input" placeholder=" " name="address[company]" value="{{form.company}}" autocapitalize="words" />
          <label for="address_company_new" class="rd-field__label">{{ 'customer.addresses.company' | t }}</label>
        </div>

        <div class="rd-field">
          <input type="text" id="address_address1_new" class="rd-field__input" placeholder=" " name="address[address1]" value="{{form.address1}}" autocapitalize="words" />
          <label for="address_address1_new" class="rd-field__label">{{ 'customer.addresses.address1' | t }}</label>
        </div>

        <div class="rd-field">
          <input type="text" id="address_address2_new" class="rd-field__input" placeholder=" " name="address[address2]" value="{{form.address2}}" autocapitalize="words" />
          <label for="address_address2_new" class="rd-field__label">{{ 'customer.addresses.address2' | t }}</label>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0 var(--rd-space-4);">
          <div class="rd-field">
            <input type="text" id="address_city_new" class="rd-field__input" placeholder=" " name="address[city]" value="{{form.city}}" autocapitalize="words" />
            <label for="address_city_new" class="rd-field__label">{{ 'customer.addresses.city' | t }}</label>
          </div>
          <div class="rd-field">
            <label for="address_country_new" class="rd-field__label" style="position:static;margin-bottom:var(--rd-space-1);color:var(--rd-text-muted);font-size:var(--rd-text-xs);">{{ 'customer.addresses.country' | t }}</label>
            <select id="address_country_new" class="rd-field__input" name="address[country]" data-default="{{form.country}}" style="padding-top:var(--rd-space-3);">{{ country_option_tags }}</select>
          </div>
        </div>

        <div id="address_province_container_new" style="display:none;">
          <div class="rd-field">
            <label for="address_province_new" class="rd-field__label" style="position:static;margin-bottom:var(--rd-space-1);color:var(--rd-text-muted);font-size:var(--rd-text-xs);">{{ 'customer.addresses.province' | t }}</label>
            <select id="address_province_new" class="rd-field__input" name="address[province]" data-default="{{form.province}}" style="padding-top:var(--rd-space-3);"></select>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0 var(--rd-space-4);">
          <div class="rd-field">
            <input type="text" id="address_zip_new" class="rd-field__input" placeholder=" " name="address[zip]" value="{{form.zip}}" autocapitalize="characters" />
            <label for="address_zip_new" class="rd-field__label">{{ 'customer.addresses.zip' | t }}</label>
          </div>
          <div class="rd-field">
            <input type="tel" id="address_phone_new" class="rd-field__input" placeholder=" " name="address[phone]" value="{{form.phone}}" />
            <label for="address_phone_new" class="rd-field__label">{{ 'customer.addresses.phone' | t }}</label>
          </div>
        </div>

        <p style="margin: var(--rd-space-4) 0;">
          {{ form.set_as_default_checkbox }}
          <label for="address_default_address_new" class="inline" style="font-size: var(--rd-text-sm); color: var(--rd-text-secondary);">{{ 'customer.addresses.set_default' | t }}</label>
        </p>

        <div class="rd-auth__actions" style="flex-direction: row;">
          <input type="submit" class="rd-btn rd-btn--primary" value="{{ 'customer.addresses.add' | t }}" />
          <button type="button" class="rd-btn rd-btn--ghost" onclick="Shopify.CustomerAddress.toggleNewForm(); return false;">{{ 'customer.addresses.cancel' | t }}</button>
        </div>
      {% endform %}
    </div>

    {% comment %}── Existing addresses ──{% endcomment %}
    <div id="address_tables">
      {% paginate customer.addresses by 10 %}
        {% if customer.addresses.size > 0 %}
          <div class="rd-addresses__grid">
            {% for address in customer.addresses %}
              <div class="rd-address-card">
                <h3 class="rd-address-card__name">
                  {{ address.first_name | capitalize }} {{ address.last_name | capitalize }}
                  {% if address == customer.default_address %}<span class="rd-address-card__default">{{ 'customer.addresses.default' | t }}</span>{% endif %}
                </h3>
                <div class="rd-address-card__body">
                  {% if address.company != blank %}{{ address.company }}<br>{% endif %}
                  {{ address.street }}<br>
                  {{ address.city | capitalize }}{% if address.province_code %}, {{ address.province_code | upcase }}{% endif %} {{ address.zip | upcase }}<br>
                  {{ address.country }}<br>
                  {{ address.phone }}
                </div>
                <div class="rd-address-card__actions">
                  <span class="rd-btn rd-btn--sm rd-btn--secondary">{{ 'customer.addresses.edit' | t | edit_customer_address_link: address.id }}</span>
                  <span class="rd-btn rd-btn--sm rd-btn--ghost" style="color: var(--rd-color-error);">{{ 'customer.addresses.delete' | t | delete_customer_address_link: address.id }}</span>
                </div>

                {% comment %}── Edit address form (hidden) ──{% endcomment %}
                <div id="edit_address_{{address.id}}" class="customer_address edit_address" style="display:none; margin-top: var(--rd-space-5); padding-top: var(--rd-space-5); border-top: 1px solid var(--rd-border-light);">
                  {% form 'customer_address', address %}
                    <h4 style="font-family: var(--rd-font-display); font-size: var(--rd-text-md); font-weight: var(--rd-weight-semibold); margin: 0 0 var(--rd-space-4);">{{ 'customer.addresses.edit_address' | t }}</h4>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0 var(--rd-space-4);">
                      <div class="rd-field">
                        <input type="text" id="address_first_name_{{form.id}}" class="rd-field__input" placeholder=" " name="address[first_name]" value="{{form.first_name}}" autocapitalize="words" />
                        <label for="address_first_name_{{form.id}}" class="rd-field__label">{{ 'customer.addresses.first_name' | t }}</label>
                      </div>
                      <div class="rd-field">
                        <input type="text" id="address_last_name_{{form.id}}" class="rd-field__input" placeholder=" " name="address[last_name]" value="{{form.last_name}}" autocapitalize="words" />
                        <label for="address_last_name_{{form.id}}" class="rd-field__label">{{ 'customer.addresses.last_name' | t }}</label>
                      </div>
                    </div>

                    <div class="rd-field">
                      <input type="text" id="address_company_{{form.id}}" class="rd-field__input" placeholder=" " name="address[company]" value="{{form.company}}" autocapitalize="words" />
                      <label for="address_company_{{form.id}}" class="rd-field__label">{{ 'customer.addresses.company' | t }}</label>
                    </div>

                    <div class="rd-field">
                      <input type="text" id="address_address1_{{form.id}}" class="rd-field__input" placeholder=" " name="address[address1]" value="{{form.address1}}" autocapitalize="words" />
                      <label for="address_address1_{{form.id}}" class="rd-field__label">{{ 'customer.addresses.address1' | t }}</label>
                    </div>

                    <div class="rd-field">
                      <input type="text" id="address_address2_{{form.id}}" class="rd-field__input" placeholder=" " name="address[address2]" value="{{form.address2}}" autocapitalize="words" />
                      <label for="address_address2_{{form.id}}" class="rd-field__label">{{ 'customer.addresses.address2' | t }}</label>
                    </div>

                    <div class="rd-field">
                      <input type="text" id="address_city_{{form.id}}" class="rd-field__input" placeholder=" " name="address[city]" value="{{form.city}}" autocapitalize="words" />
                      <label for="address_city_{{form.id}}" class="rd-field__label">{{ 'customer.addresses.city' | t }}</label>
                    </div>

                    <div class="rd-field">
                      <label for="address_country_{{form.id}}" class="rd-field__label" style="position:static;margin-bottom:var(--rd-space-1);color:var(--rd-text-muted);font-size:var(--rd-text-xs);">{{ 'customer.addresses.country' | t }}</label>
                      <select id="address_country_{{form.id}}" class="rd-field__input" name="address[country]" data-default="{{form.country}}" style="padding-top:var(--rd-space-3);">{{ country_option_tags }}</select>
                    </div>

                    <div id="address_province_container_{{form.id}}" style="display:none;">
                      <div class="rd-field">
                        <label for="address_province_{{form.id}}" class="rd-field__label" style="position:static;margin-bottom:var(--rd-space-1);color:var(--rd-text-muted);font-size:var(--rd-text-xs);">{{ 'customer.addresses.province' | t }}</label>
                        <select id="address_province_{{form.id}}" class="rd-field__input" name="address[province]" data-default="{{form.province}}" style="padding-top:var(--rd-space-3);"></select>
                      </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0 var(--rd-space-4);">
                      <div class="rd-field">
                        <input type="text" id="address_zip_{{form.id}}" class="rd-field__input" placeholder=" " name="address[zip]" value="{{form.zip}}" autocapitalize="characters" />
                        <label for="address_zip_{{form.id}}" class="rd-field__label">{{ 'customer.addresses.zip' | t }}</label>
                      </div>
                      <div class="rd-field">
                        <input type="tel" id="address_phone_{{form.id}}" class="rd-field__input" placeholder=" " name="address[phone]" value="{{form.phone}}" />
                        <label for="address_phone_{{form.id}}" class="rd-field__label">{{ 'customer.addresses.phone' | t }}</label>
                      </div>
                    </div>

                    <p style="margin: var(--rd-space-4) 0;">
                      {{ form.set_as_default_checkbox }}
                      <label for="address_default_address_{{form.id}}" class="inline" style="font-size: var(--rd-text-sm); color: var(--rd-text-secondary);">{{ 'customer.addresses.set_default' | t }}</label>
                    </p>

                    <div class="rd-auth__actions" style="flex-direction: row;">
                      <input type="submit" class="rd-btn rd-btn--primary" value="{{ 'customer.addresses.update' | t }}" />
                      <button type="button" class="rd-btn rd-btn--ghost" onclick="Shopify.CustomerAddress.toggleForm({{form.id}}); return false;">{{ 'customer.addresses.cancel' | t }}</button>
                    </div>
                  {% endform %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="rd-account__empty">
            <p>{{ 'customer.addresses.no_addresses' | t }}</p>
          </div>
        {% endif %}

        <div id="address_pagination" style="margin-top: var(--rd-space-8);">{{ paginate | default_pagination }}</div>
      {% endpaginate %}
    </div>
  </div>
</div>

<script type="text/javascript" charset="utf-8" data-no-instant>
  new Shopify.CountryProvinceSelector('address_country_new', 'address_province_new', {hideElement: 'address_province_container_new'});
  {% for address in customer.addresses %}
    new Shopify.CountryProvinceSelector('address_country_{{address.id}}', 'address_province_{{address.id}}', {hideElement: 'address_province_container_{{address.id}}'});
  {% endfor %}
</script>
