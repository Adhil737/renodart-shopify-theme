{% comment %}
  RenoDart Slideshow — Phase 5
  ─────────────────────────────
  CRITICAL TURBO JS HOOKS PRESERVED (NEVER REMOVE):
  · #homepage_slider-{id}         → Flickity init
  · .js-homepage-slideshow        → Flickity init
  · .homepage-slideshow           → Flickity init
  · .slideshow-section            → section class
  · .under-menu                   → layout class
  · data-slider-id                → Flickity config
  · data-slideshow-speed          → Flickity speed
  · data-slideshow-text-animation → text animation
  · .gallery-cell                 → Flickity slide wrapper
  · .js-caption                   → caption JS hook
  · .caption / .position-*        → text positioning
  · .banner-full-link             → full slide link
  · .action_button                → button hook
  · .first_button / .second_button → button classes
  · .highlight-true/false         → button highlight
  · slideshow_animation--{value}  → transition class
  · text-animation--true          → animation class
  New: rd-hero overlay, rd-btn button classes layered on top of
  existing classes, eyebrow support, modern button styles per block.
{% endcomment %}

{% assign default = '1400x' %}
{% assign size1  = '480x'  %}{% assign size2  = '768x'  %}{% assign size3  = '900x'  %}
{% assign size4  = '1100x' %}{% assign size5  = '1280x' %}{% assign size6  = '1400x' %}
{% assign size7  = '1600x' %}{% assign size8  = '1800x' %}{% assign size9  = '2000x' %}

{% if section.blocks.size > 0 %}
  <section id="homepage_slider-{{ section.id }}"
           class="rd-slideshow homepage-slideshow js-homepage-slideshow
                  slideshow_animation--{{ section.settings.slideshow_animation }}
                  {% if section.settings.slideshow_text_animation != '' %}text-animation--true{% endif %}"
           data-slider-id="homepage_slider-{{ section.id }}"
           data-slideshow-speed="{{ section.settings.slideshow_speed }}"
           data-slideshow-text-animation="{{ section.settings.slideshow_text_animation }}">

    {% for block in section.blocks %}
      <div class="gallery-cell rd-slideshow__slide slide-{{ forloop.index }}"
           {{ block.shopify_attributes }}
           data-block-id="{{ block.id }}">

        {% comment %}── Slide image ──{% endcomment %}
        {% if block.settings.image != nil %}
          <img src="{{ block.settings.image | img_url: '100x', format: 'pjpg' }}"
               alt="{{ block.settings.image.alt | escape }}"
               class="rd-slideshow__img lazyload {{ settings.image_loading_style }}"
               sizes="100vw"
               data-src="{{ block.settings.image | img_url: default, format: 'pjpg' }}"
               srcset="{{ block.settings.image | img_url: size1, format: 'pjpg' }} {{ size1 | replace: 'x', 'w' }},
                       {{ block.settings.image | img_url: size2, format: 'pjpg' }} {{ size2 | replace: 'x', 'w' }},
                       {{ block.settings.image | img_url: size3, format: 'pjpg' }} {{ size3 | replace: 'x', 'w' }},
                       {{ block.settings.image | img_url: size4, format: 'pjpg' }} {{ size4 | replace: 'x', 'w' }},
                       {{ block.settings.image | img_url: size5, format: 'pjpg' }} {{ size5 | replace: 'x', 'w' }},
                       {{ block.settings.image | img_url: size6, format: 'pjpg' }} {{ size6 | replace: 'x', 'w' }},
                       {{ block.settings.image | img_url: size7, format: 'pjpg' }} {{ size7 | replace: 'x', 'w' }},
                       {{ block.settings.image | img_url: size8, format: 'pjpg' }} {{ size8 | replace: 'x', 'w' }},
                       {{ block.settings.image | img_url: size9, format: 'pjpg' }} {{ size9 | replace: 'x', 'w' }},
                       {{ block.settings.image | img_url: default, format: 'pjpg' }} {{ default | replace: 'x', 'w' }}"
               width="1400" height="700"
               {% if forloop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %} />
        {% else %}
          {% capture i %}{% cycle "1", "2" %}{% endcapture %}
          {{ 'lifestyle-' | append: i | placeholder_svg_tag: 'placeholder-svg placeholder-svg--slideshow rd-slideshow__placeholder' }}
        {% endif %}

        {% comment %}── Cinematic overlay ──{% endcomment %}
        {% if block.settings.overlay_style != 'none' %}
          <div class="rd-slideshow__overlay rd-slideshow__overlay--{{ block.settings.overlay_style | default: 'gradient' }}" aria-hidden="true"></div>
        {% endif %}

        {% comment %}── Full-slide link (preserved Turbo hook) ──{% endcomment %}
        {% unless block.settings.button1_link != blank and block.settings.button2_link != blank %}
          {% if block.settings.button1_link != blank %}
            <a href="{{ block.settings.button1_link }}" class="banner-full-link rd-slideshow__full-link" aria-label="{{ block.settings.title | escape }}"></a>
          {% elsif block.settings.button2_link != blank %}
            <a href="{{ block.settings.button2_link }}" class="banner-full-link rd-slideshow__full-link" aria-label="{{ block.settings.title | escape }}"></a>
          {% endif %}
        {% endunless %}

        {% comment %}── Caption (all Turbo hooks preserved) ──{% endcomment %}
        {% if block.settings.pretext != blank or block.settings.title != blank or block.settings.subtitle != blank or block.settings.button1 != blank or block.settings.button2 != blank %}
          <div class="caption position-{{ block.settings.text_position }} js-caption rd-slideshow__caption">
            <div class="caption-content
                        caption-background-{{ block.settings.caption_background }}
                        caption-transparency-{{ block.settings.caption_background_transparency }}
                        align-{{ block.settings.text_align }}
                        rd-slideshow__caption-inner">

              {% if block.settings.pretext != blank %}
                <div class="pretext rd-eyebrow rd-slideshow__eyebrow">{{ block.settings.pretext }}</div>
              {% endif %}

              {% if forloop.first and block.settings.title != blank %}
                <h1 class="headline rd-slideshow__heading rd-display-hero">{{ block.settings.title }}</h1>
              {% elsif block.settings.title != blank %}
                <p class="headline rd-slideshow__heading rd-display-hero">{{ block.settings.title }}</p>
              {% endif %}

              {% if block.settings.subtitle != blank %}
                <div class="subtitle rd-slideshow__subtitle">{{ block.settings.subtitle }}</div>
              {% endif %}

              {% if block.settings.button1 != blank or block.settings.button2 != blank %}
                <div class="rd-hero__cta-group">
                  {% if block.settings.button1 != blank %}
                    <a {% if block.settings.button1_link != blank %}href="{{ block.settings.button1_link }}"{% endif %}
                       class="action_button first_button highlight-{{ block.settings.button1_highlight }} rd-btn {% if block.settings.button1_style == 'cta' %}rd-btn--cta{% elsif block.settings.button1_style == 'secondary' %}rd-btn--secondary{% else %}rd-btn--primary{% endif %} rd-btn--lg">
                      {{ block.settings.button1 }}
                    </a>
                  {% endif %}
                  {% if block.settings.button2 != blank %}
                    <a {% if block.settings.button2_link != blank %}href="{{ block.settings.button2_link }}"{% endif %}
                       class="action_button second_button highlight-{{ block.settings.button2_highlight }} rd-btn {% if block.settings.button2_style == 'secondary' %}rd-btn--secondary{% else %}rd-btn--ghost{% endif %} rd-btn--lg">
                      {{ block.settings.button2 }}
                    </a>
                  {% endif %}
                </div>
              {% endif %}

            </div>
          </div>
        {% endif %}

      </div>
    {% endfor %}

  </section>
{% endif %}

{% schema %}
{
  "name": "Slideshow",
  "class": "slideshow-section under-menu",
  "settings": [
    {
      "type": "paragraph",
      "content": "Best results: images 1600px wide, under 700px tall. Keep all slides the same dimensions."
    },
    {
      "type": "header",
      "content": "Slideshow Settings"
    },
    {
      "type": "select",
      "id": "slideshow_text_animation",
      "label": "Text animation",
      "options": [
        { "value": "",          "label": "None" },
        { "value": "fadeIn",    "label": "Fade In" },
        { "value": "fadeInUp",  "label": "Fade Up" },
        { "value": "fadeInDown","label": "Fade Down" }
      ],
      "default": "fadeInDown"
    },
    {
      "type": "select",
      "id": "slideshow_animation",
      "label": "Slide transition",
      "options": [
        { "value": "slide", "label": "Slide" },
        { "value": "fade",  "label": "Fade" }
      ],
      "default": "slide"
    },
    {
      "type": "select",
      "id": "slideshow_speed",
      "label": "Auto-advance speed",
      "default": "6000",
      "options": [
        { "value": "0",     "label": "Manual only" },
        { "value": "4000",  "label": "4 seconds" },
        { "value": "6000",  "label": "6 seconds" },
        { "value": "10000", "label": "10 seconds" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide image",
          "info": "1600 x 700px recommended"
        },
        {
          "type": "select",
          "id": "overlay_style",
          "label": "Overlay style",
          "options": [
            { "value": "gradient", "label": "Cinematic gradient" },
            { "value": "dark",     "label": "Dark solid" },
            { "value": "purple",   "label": "Purple brand" },
            { "value": "none",     "label": "None" }
          ],
          "default": "gradient"
        },
        {
          "type": "header",
          "content": "Text Content"
        },
        {
          "type": "richtext",
          "id": "pretext",
          "label": "Eyebrow / preheading",
          "default": "<p></p>"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Your headline"
        },
        {
          "type": "richtext",
          "id": "subtitle",
          "label": "Subheading",
          "default": "<p></p>"
        },
        {
          "type": "select",
          "id": "text_position",
          "label": "Text position",
          "options": [
            { "value": "left",   "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Text alignment",
          "options": [
            { "value": "left",   "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "checkbox",
          "id": "caption_background",
          "label": "Show text background box"
        },
        {
          "type": "checkbox",
          "id": "caption_background_transparency",
          "label": "Make text background transparent"
        },
        {
          "type": "header",
          "content": "Primary Button"
        },
        {
          "type": "text",
          "id": "button1",
          "label": "Button 1 text"
        },
        {
          "type": "url",
          "id": "button1_link",
          "label": "Button 1 link"
        },
        {
          "type": "select",
          "id": "button1_style",
          "label": "Button 1 style",
          "options": [
            { "value": "cta",       "label": "Gradient CTA" },
            { "value": "primary",   "label": "Solid purple" },
            { "value": "secondary", "label": "Outline" }
          ],
          "default": "cta"
        },
        {
          "type": "checkbox",
          "id": "button1_highlight",
          "label": "Highlight button 1"
        },
        {
          "type": "header",
          "content": "Secondary Button"
        },
        {
          "type": "text",
          "id": "button2",
          "label": "Button 2 text"
        },
        {
          "type": "url",
          "id": "button2_link",
          "label": "Button 2 link"
        },
        {
          "type": "select",
          "id": "button2_style",
          "label": "Button 2 style",
          "options": [
            { "value": "ghost",     "label": "Ghost (glass)" },
            { "value": "secondary", "label": "Outline" }
          ],
          "default": "ghost"
        },
        {
          "type": "checkbox",
          "id": "button2_highlight",
          "label": "Highlight button 2"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "category": "Image",
      "settings": {
        "slideshow_animation": "slide",
        "slideshow_speed": "6000"
      },
      "blocks": [
        {
          "type": "image",
          "settings": {
            "title": "Your Headline",
            "text_align": "center",
            "overlay_style": "gradient",
            "button1_style": "cta",
            "button2_style": "ghost"
          }
        },
        {
          "type": "image",
          "settings": {
            "title": "Second Slide",
            "text_align": "center",
            "overlay_style": "gradient"
          }
        }
      ]
    }
  ]
}
{% endschema %}
