{% comment %}
  RenoDart Collection List — Phase 6
  ─────────────────────────────────────
  TURBO HOOKS PRESERVED:
  · .collection-list-section     → section class
  · .thumbnail / .product-wrap   → Turbo JS hover hooks
  · .hidden-product-link         → Turbo JS hook
  · .thumbnail-overlay           → settings.thumbnail_hover_enabled
  · .lazyload / data-src/srcset  → LazySizes
  · settings.thumbnail_hover_enabled → Turbo hover JS
  · .collection-info__caption    → Turbo caption JS
  New: rd-collection-card overlay variant replaces float grid,
  CSS Grid layout, cinematic hover overlay, responsive grid,
  per-row setting honored, section header component.
{% endcomment %}

{% assign collections_per_row = section.settings.frontpage_collections_per_row %}

{% comment %}── Map per-row to grid class ──{% endcomment %}
{% assign grid_class = 'rd-collection-list__grid--three' %}
{% if collections_per_row == "2" %}{% assign grid_class = 'rd-collection-list__grid--two' %}
{% elsif collections_per_row == "3" %}{% assign grid_class = 'rd-collection-list__grid--three' %}
{% elsif collections_per_row == "4" %}{% assign grid_class = 'rd-collection-list__grid--four' %}
{% elsif collections_per_row == "5" %}{% assign grid_class = 'rd-collection-list__grid--five' %}
{% endif %}

<section class="rd-collection-list collection-list-section">
  <div class="rd-container">

    {% if section.blocks.size > 0 %}

      {% comment %}── Section header ──{% endcomment %}
      {% if section.settings.title != blank %}
        <div class="rd-section-header rd-section-header--center rd-reveal">
          <div class="rd-section-header__copy">
            <h2 class="rd-heading-2 rd-section-header__title title">{{ section.settings.title }}</h2>
            <hr class="rd-divider feature_divider" />
          </div>
        </div>
      {% endif %}

      {% comment %}── Collection grid ──{% endcomment %}
      <div class="section list-collection-wrapper">
        <div class="list-collections rd-collection-list__grid {{ grid_class }} rd-stagger">

          {% for block in section.blocks %}
            {% assign feature_collection = block.settings.feature_collection %}
            {% assign collection = collections[feature_collection] %}

            {% comment %}── Image priority: block override → collection image → first product ──{% endcomment %}
            {% if block.settings.image %}
              {% assign collection_image = block.settings.image %}
              {% assign collection_image_alt = block.settings.image.alt | escape %}
            {% elsif collection.image != blank %}
              {% assign collection_image = collection.image %}
              {% assign collection_image_alt = collection.title | escape %}
            {% elsif collection.empty? == false and collection.products.first.featured_image %}
              {% assign collection_image = collection.products.first.featured_image %}
              {% assign collection_image_alt = collection.products.first.featured_image.alt | escape %}
            {% else %}
              {% assign collection_image = nil %}
            {% endif %}

            <div class="rd-collection-card thumbnail {% cycle 'even', 'odd' %} rd-reveal" {{ block.shopify_attributes }}>

              <div class="product-wrap rd-collection-card__img-wrap">

                {% comment %}── Collection image ──{% endcomment %}
                {% if collection_image != nil %}
                  <img src="{{ collection_image.src | img_url: '100x' }}"
                       alt="{{ collection_image_alt }}"
                       class="rd-collection-card__img lazyload {{ settings.image_loading_style }}"
                       data-src="{{ collection_image.src | img_url: '580x', crop: 'center' }}"
                       data-sizes="auto"
                       data-srcset="{{ collection_image.src | img_url: '380x', crop: 'center' }} 380w,
                                    {{ collection_image.src | img_url: '580x', crop: 'center' }} 580w,
                                    {{ collection_image.src | img_url: '760x', crop: 'center' }} 760w"
                       width="580" height="640"
                       loading="{% if forloop.index <= 4 %}eager{% else %}lazy{% endif %}" />
                {% else %}
                  {% capture num %}{% cycle "1", "2", "3", "4", "5", "6" %}{% endcapture %}
                  {{ 'collection-' | append: num | placeholder_svg_tag: 'placeholder-svg rd-collection-card__placeholder' }}
                {% endif %}

                {% comment %}── Hover overlay (RenoDart) ──{% endcomment %}
                <div class="rd-collection-card__overlay">
                  <div class="rd-collection-card__content">
                    <h3 class="rd-collection-card__title">
                      {% if collection != blank %}
                        {{ collection.title }}
                      {% else %}
                        {{ "homepage.onboarding.collection_title" | t }}
                      {% endif %}
                    </h3>
                    <a href="{{ collection.url }}" class="rd-collection-card__view" aria-label="Shop {{ collection.title | escape }}">
                      {{ 'collections.general.view_all' | t }}
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                  </div>
                </div>

                {% comment %}── Hidden link (Turbo JS compatibility hook) ──{% endcomment %}
                <a href="{{ collection.url }}" class="hidden-product-link" tabindex="-1" aria-hidden="true">
                  {% if collection != blank %}{{ collection.title }}{% else %}{{ "homepage.onboarding.collection_title" | t }}{% endif %}
                </a>

                {% comment %}── Turbo thumbnail hover overlay (settings.thumbnail_hover_enabled) ──{% endcomment %}
                {% if settings.thumbnail_hover_enabled %}
                  <div class="thumbnail-overlay">
                    <a href="{{ collection.url }}" class="hidden-product-link" tabindex="-1" aria-hidden="true">
                      {% if collection != blank %}{{ collection.title }}{% else %}{{ "homepage.onboarding.collection_title" | t }}{% endif %}
                    </a>
                    <div class="info">
                      <div class="collection-details">
                        <span class="title">
                          {% if collection != blank %}{{ collection.title }}{% else %}{{ "homepage.onboarding.collection_title" | t }}{% endif %}
                        </span>
                      </div>
                      <a href="{{ collection.url }}"><span class="view_all">{{ 'collections.general.view_all' | t }}</span></a>
                    </div>
                  </div>
                {% endif %}

                {% comment %}── Caption (Turbo JS compatibility) ──{% endcomment %}
                <a class="collection-info__caption {% if settings.thumbnail_hover_enabled %}hidden{% endif %}"
                   href="{{ collection.url }}" itemprop="url">
                  <span class="title">
                    {% if collection != blank %}{{ collection.title }}{% else %}{{ "homepage.onboarding.collection_title" | t }}{% endif %}
                  </span>
                </a>

              </div>
            </div>

          {% endfor %}
        </div>
      </div>

    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "class": "collection-list-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Collection"
    },
    {
      "type": "select",
      "id": "frontpage_collections_per_row",
      "label": "Collections per row",
      "options": [
        {"value": "2", "label": "2"},
        {"value": "3", "label": "3"},
        {"value": "4", "label": "4"},
        {"value": "5", "label": "5"}
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "feature_collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image override"
        }
      ]
    }
  ],
  "presets": [{
    "name": "Collection list",
    "category": "Collection",
    "blocks": [
      {"type": "collection"},
      {"type": "collection"},
      {"type": "collection"}
    ]
  }]
}
{% endschema %}
