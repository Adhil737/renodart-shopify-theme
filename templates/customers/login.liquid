<a name="pagecontent" id="pagecontent"></a>

<div class="rd-auth container main content">
  <div class="sixteen columns">
    <div class="rd-auth__header">
      <h1 class="rd-auth__title">{{ 'customer.login.title' | t }}</h1>
      <p class="rd-auth__subtitle">{{ 'customer.login.subtitle' | t | default: 'Welcome back. Sign in to your account.' }}</p>
    </div>

    <div class="rd-auth__card" id="customer">
      {% form 'customer_login' %}
        {% if form.errors %}
          <div class="rd-auth__errors">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="rd-field">
          <input type="email" value="" name="customer[email]" id="customer_email"
                 class="rd-field__input" placeholder=" " autocorrect="off" autocapitalize="off" required />
          <label for="customer_email" class="rd-field__label">{{ 'customer.login.email' | t }}</label>
        </div>

        {% if form.password_needed %}
          <div class="rd-field">
            <input type="password" value="" name="customer[password]" id="customer_password"
                   class="rd-field__input" placeholder=" " required />
            <label for="customer_password" class="rd-field__label">{{ 'customer.login.password' | t }}</label>
          </div>
        {% endif %}

        <div class="rd-auth__actions">
          <input type="submit" class="rd-btn rd-btn--primary rd-btn--lg" value="{{ 'customer.login.sign_in' | t }}" />
        </div>

        {% if form.password_needed %}
          <div class="rd-auth__links">
            <a href="#" onclick="showRecoverPasswordForm(); return false;" class="rd-auth__link">
              {{ 'customer.login.forgot_password' | t }}
            </a>
            {% unless shop.checkout.guest_login %}
              <span>
                {{ 'customer.login.new_customer_label' | t | default: 'No account?' }}
                <a href="/account/register" class="rd-auth__link">{{ 'customer.login.sign_up_html' | t | default: 'Create one' }}</a>
              </span>
            {% endunless %}
          </div>
        {% endif %}
      {% endform %}

      {% if shop.checkout.guest_login %}
        <div class="rd-auth__divider">{{ 'customer.login.or' | t }}</div>
        {% form 'guest_login' %}
          <input class="rd-btn rd-btn--ghost rd-btn--full" type="submit" value="{{ 'customer.login.guest_title_html' | t }}" />
        {% endform %}
      {% endif %}
    </div>

    {% comment %}── Recover password inline ──{% endcomment %}
    <div id="recover-password" style="display:none;">
      <div class="rd-auth__card" style="margin-top: var(--rd-space-8);">
        <h2 class="rd-auth__title" style="font-size: var(--rd-text-xl); text-align: center;">{{ 'customer.recover_password.title' | t }}</h2>

        {% form 'recover_customer_password' %}
          {% if form.errors %}
            <div class="rd-auth__errors">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          {% if form.posted_successfully? %}
            {% assign reset_success = true %}
          {% endif %}

          <div class="rd-field">
            <input type="email" value="" name="email" id="recover-email"
                   class="rd-field__input" placeholder=" " autocorrect="off" autocapitalize="off" required />
            <label for="recover-email" class="rd-field__label">{{ 'customer.recover_password.email' | t }}</label>
          </div>

          <p class="rd-auth__subtitle" style="text-align: center; margin-bottom: var(--rd-space-5);">
            <em>{{ 'customer.recover_password.subtext' | t }}</em>
          </p>

          <div class="rd-auth__actions">
            <input type="submit" class="rd-btn rd-btn--primary rd-btn--lg" value="{{ 'customer.recover_password.submit' | t }}" />
          </div>

          <div class="rd-auth__links" style="justify-content: center;">
            <a href="#" onclick="hideRecoverPasswordForm(); return false;" class="rd-auth__link">
              {{ 'customer.recover_password.cancel' | t }}
            </a>
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
  function showRecoverPasswordForm() {
    document.getElementById('recover-password').style.display = '';
    document.getElementById('customer').style.display = 'none';
    return false;
  }

  function hideRecoverPasswordForm() {
    document.getElementById('recover-password').style.display = 'none';
    document.getElementById('customer').style.display = '';
    return false;
  }

  if (window.location.hash == '#recover') { showRecoverPasswordForm(); }

  {% if reset_success %}
    showRecoverPasswordForm();
  {% endif %}
</script>
